{# templates/chat/index.html.twig #}
{% extends 'admin/base_admin.html.twig' %}
{% block title %}Chat AI - Mistral{% endblock %}

{% block admin_content %}
<div class="admin-main-content">
    <div class="container-fluid py-4">

        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item active">
                    <i class="fas fa-robot me-1"></i>Chat AI
                </li>
            </ol>
        </nav>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                    {# Header #}
                    <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <div class="d-flex align-items-center">
                            <div class="me-3 bg-white bg-opacity-25 rounded-circle p-2">
                                <i class="fas fa-robot fa-lg"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 fw-bold">Mistral AI</h5>
                                <small class="opacity-75">
                                    <span class="badge bg-success me-1">●</span>En ligne
                                </small>
                            </div>
                        </div>
                    </div>

                    {# Messages #}
                    <div class="card-body p-0">
                        <div id="chat-messages" style="height: 500px; overflow-y: auto; padding: 20px; background: #f8f9fa;">

                            {# Message de bienvenue #}
                            <div class="d-flex mb-3">
                                <div class="avatar-ai me-2">
                                    <i class="fas fa-robot"></i>
                                </div>
                                <div class="message-bubble ai-bubble">
                                    Bonjour ! Je suis Pedagogy_chat. Comment puis-je vous aider ? 🤖
                                </div>
                            </div>

                        </div>
                    </div>

                    {# Input #}
                    <div class="card-footer bg-white border-top p-3">
                        <div class="input-group">
                            <input
                                type="text"
                                id="user-input"
                                class="form-control form-control-lg border-2 rounded-3"
                                placeholder="Écrivez votre message..."
                                style="border-color: #667eea;"
                            >
                            <button id="send-btn" class="btn btn-lg ms-2 text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                        <small class="text-muted mt-2 d-block text-center">
                            <i class="fas fa-info-circle me-1"></i>
                            Propulsé par Mistral via Ollama
                        </small>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
.admin-main-content {
    margin-left: 280px;
    padding: 100px 40px 40px 40px;
    min-height: 100vh;
    background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
}

.message-bubble {
    max-width: 75%;
    padding: 12px 16px;
    border-radius: 18px;
    font-size: 0.95rem;
    line-height: 1.5;
    word-wrap: break-word;
}

.ai-bubble {
    background: white;
    color: #2d3748;
    border-bottom-left-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.user-bubble {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-bottom-right-radius: 4px;
    margin-left: auto;
}

.avatar-ai {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.85rem;
    flex-shrink: 0;
}

.avatar-user {
    width: 36px;
    height: 36px;
    background: #2d3748;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.85rem;
    flex-shrink: 0;
}

.typing-indicator span {
    width: 8px;
    height: 8px;
    background: #667eea;
    border-radius: 50%;
    display: inline-block;
    animation: typing 1s infinite;
}
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
}

@media (max-width: 768px) {
    .admin-main-content { margin-left: 0; padding: 20px 15px; }
}
</style>

<script>
const chatMessages = document.getElementById('chat-messages');
const userInput = document.getElementById('user-input');
const sendBtn = document.getElementById('send-btn');

function addMessage(content, isUser) {
    const wrapper = document.createElement('div');
    wrapper.className = 'd-flex mb-3' + (isUser ? ' justify-content-end' : '');

    if (!isUser) {
        wrapper.innerHTML = `
            <div class="avatar-ai me-2"><i class="fas fa-robot"></i></div>
            <div class="message-bubble ai-bubble">${content}</div>
        `;
    } else {
        wrapper.innerHTML = `
            <div class="message-bubble user-bubble">${content}</div>
            <div class="avatar-user ms-2"><i class="fas fa-user"></i></div>
        `;
    }

    chatMessages.appendChild(wrapper);
    chatMessages.scrollTop = chatMessages.scrollHeight;
}

function showTyping() {
    const typing = document.createElement('div');
    typing.className = 'd-flex mb-3';
    typing.id = 'typing-indicator';
    typing.innerHTML = `
        <div class="avatar-ai me-2"><i class="fas fa-robot"></i></div>
        <div class="message-bubble ai-bubble typing-indicator">
            <span></span><span></span><span></span>
        </div>
    `;
    chatMessages.appendChild(typing);
    chatMessages.scrollTop = chatMessages.scrollHeight;
}

function removeTyping() {
    const typing = document.getElementById('typing-indicator');
    if (typing) typing.remove();
}

async function sendMessage() {
    const message = userInput.value.trim();
    if (!message) return;

    addMessage(message, true);
    userInput.value = '';
    sendBtn.disabled = true;
    showTyping();

    try {
        const response = await fetch('{{ path("chat_send") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: message })
        });

        const data = await response.json();
        removeTyping();

        if (data.reply) {
            addMessage(data.reply, false);
        } else {
            addMessage('❌ Erreur: ' + (data.error ?? 'Inconnue'), false);
        }

    } catch (err) {
        removeTyping();
        addMessage('❌ Impossible de contacter Ollama. Vérifiez qu\'il est lancé.', false);
    }

    sendBtn.disabled = false;
    userInput.focus();
}

sendBtn.addEventListener('click', sendMessage);
userInput.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') sendMessage();
});
</script>

{% endblock %}