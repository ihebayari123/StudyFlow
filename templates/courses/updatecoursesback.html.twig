{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
<div class="admin-main-content">
    <div class="container-fluid px-4">
        <!-- Page Header with improved styling -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-0 text-gray-800">
                    <i class="fas fa-edit me-2 text-primary"></i>Update Course
                </h1>
                <p class="text-muted mt-2">Edit the course details below</p>
            </div>
            <div>
                <span class="badge bg-primary bg-gradient px-3 py-2">
                    <i class="fas fa-pen me-1"></i> Editing Mode
                </span>
            </div>
        </div>

        <div class="row">
            <!-- Main Form Card -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        {{ form_start(f, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                        
                        <!-- Course Title -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-heading text-primary me-2"></i>Course Title
                            </label>
                            <div class="form-floating">
                                {{ form_widget(f.titre, {
                                    'attr': {
                                        'class': 'form-control rounded-3',
                                        'placeholder': 'Enter course title',
                                        'id': 'courseTitle'
                                    }
                                }) }}
                                {{ form_label(f.titre, 'Course Title', {'label_attr': {'for': 'courseTitle'}}) }}
                                {{ form_errors(f.titre) }}
                            </div>
                            <small class="text-muted">Give your course a clear, descriptive title</small>
                        </div>

                        <!-- Course Description -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-align-left text-primary me-2"></i>Course Description
                            </label>
                            {{ form_widget(f.description, {
                                'attr': {
                                    'class': 'form-control rounded-3',
                                    'placeholder': 'Write a comprehensive description of your course...',
                                    'rows': '6',
                                    'style': 'min-height: 150px;'
                                }
                            }) }}
                            {{ form_errors(f.description) }}
                            <small class="text-muted">Describe what students will learn and course requirements</small>
                        </div>

                        <!-- Course Image Upload Section -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-image text-primary me-2"></i>Course Image
                            </label>
                            
                            <!-- Hidden file input -->
                            {{ form_widget(f.imageFile, {
                                'attr': {
                                    'accept': 'image/*',
                                    'id': 'courseImage',
                                    'style': 'display: none;'
                                }
                            }) }}
                            
                            <div class="upload-area border rounded-3 p-4 text-center" id="uploadArea">
                                <div class="upload-content" id="uploadContent">
                                    <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-3"></i>
                                    <h5 class="mb-2">Click to upload or drag and drop</h5>
                                    <p class="text-muted mb-3">JPG, PNG or GIF (Max 2MB)</p>
                                    
                                    <!-- Custom upload button -->
                                    <button type="button" class="btn btn-primary px-4" id="uploadButton">
                                        <i class="fas fa-upload me-2"></i>Choose New Image
                                    </button>
                                </div>
                                
                                <!-- Image Preview (hidden initially) -->
                                <div class="image-preview" id="imagePreview" style="display: none;">
                                    <div class="position-relative">
                                        <img src="#" alt="Preview" class="img-fluid rounded-3" style="max-height: 200px;">
                                        <div class="mt-3">
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeImage()">
                                                <i class="fas fa-trash me-1"></i>Remove
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="changeImage()">
                                                <i class="fas fa-exchange-alt me-1"></i>Change
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Current Image Display (if exists) -->
                            <div class="current-image mt-3" id="currentImageContainer">
                                <label class="small text-muted mb-2">Current Image:</label>
                                <div class="d-flex align-items-center">
                                    <img src="#" alt="Current course image" class="rounded-3 me-3" style="width: 80px; height: 80px; object-fit: cover; border: 2px solid #e0e0e0;">
                                    <div>
                                        <p class="mb-1"><strong>current-image.jpg</strong></p>
                                        <small class="text-muted">Uploading a new image will replace this one</small>
                                    </div>
                                </div>
                            </div>
                            
                            {{ form_errors(f.imageFile) }}
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex gap-3 justify-content-end pt-3 border-top">
                            <a href="{{ path('app_showcoursesback') }}" class="btn btn-outline-secondary btn-lg px-4 rounded-3">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-5 rounded-3 shadow-sm">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                        </div>
                        
                        {{ form_end(f) }}
                    </div>
                </div>
            </div>

            <!-- Side Panel with Tips -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-header bg-transparent border-0 pt-4">
                        <h5 class="mb-0">
                            <i class="fas fa-lightbulb text-warning me-2"></i>
                            Editing Tips
                        </h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-3">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong>Title:</strong> Keep it concise and searchable
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong>Description:</strong> Update learning outcomes
                            </li>
                            <li class="mb-3">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong>Image:</strong> Use high-quality images
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 bg-gradient-success text-white">
                    <div class="card-body p-4">
                        <h5 class="text-white mb-3">
                            <i class="fas fa-sync-alt me-2"></i>Update Info
                        </h5>
                        <p class="small opacity-75 mb-0">
                            <i class="fas fa-clock me-2"></i>Last updated: Just now<br>
                            <i class="fas fa-history me-2 mt-2"></i>Version history available
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom Styles -->
<style>
    /* Main container adjustments */
    .admin-main-content {
        margin-left: 280px;
        padding: 30px 40px 40px 40px;
        transition: all 0.3s;
    }

    /* Card styles */
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.1) !important;
    }

    /* Upload Area Styling */
    .upload-area {
        background-color: #f8f9fa;
        border: 2px dashed #dee2e6 !important;
        transition: all 0.3s;
        cursor: pointer;
    }

    .upload-area:hover {
        background-color: #e9ecef;
        border-color: #4f46e5 !important;
    }

    .upload-area.dragover {
        background-color: #e3f2fd;
        border-color: #4f46e5 !important;
    }

    /* Image preview styling */
    .image-preview img {
        border: 3px solid #4f46e5;
        padding: 3px;
        background: white;
    }

    /* Form field enhancements */
    .form-control {
        border: 1px solid #e0e0e0;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 0.2rem rgba(79, 70, 229, 0.1);
    }

    .form-floating > label {
        color: #6c757d;
        font-weight: 400;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #4f46e5;
        font-weight: 500;
        transform: scale(0.85) translateY(-0.5rem) translateX(0.15rem);
    }

    /* Badge styling */
    .badge.bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .bg-gradient-success {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    }

    /* Button styles */
    .btn-success {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        border: none;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1.5rem rgba(40, 167, 69, 0.3) !important;
    }

    .btn-outline-secondary:hover {
        background-color: #f8f9fa;
        border-color: #6c757d;
    }

    /* List styling */
    .list-unstyled li {
        padding: 8px 12px;
        background: #f8f9fa;
        border-radius: 8px;
        transition: background 0.2s;
    }

    .list-unstyled li:hover {
        background: #e9ecef;
    }

    /* Current image styling */
    .current-image img {
        border: 2px solid #e0e0e0;
        transition: transform 0.2s;
    }

    .current-image img:hover {
        transform: scale(1.05);
    }

    /* Responsive adjustments */
    @media (max-width: 991.98px) {
        .admin-main-content {
            margin-left: 0;
            padding: 20px;
        }
    }

    /* Animation for buttons */
    .btn:active {
        transform: scale(0.95);
    }

    /* Error message styling */
    .form-error {
        color: #dc3545;
        font-size: 0.875rem;
        margin-top: 0.25rem;
        padding-left: 0.5rem;
    }
</style>

<!-- JavaScript for Image Upload -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Find the file input dynamically - Symfony generates unique IDs
        const fileInput = document.querySelector('input[type="file"][name*="imageFile"]');
        const uploadArea = document.getElementById('uploadArea');
        const uploadButton = document.getElementById('uploadButton');
        const uploadContent = document.getElementById('uploadContent');
        const imagePreview = document.getElementById('imagePreview');
        const currentImageContainer = document.getElementById('currentImageContainer');
        
        console.log('File input found:', fileInput); // Debug
        
        if (!fileInput) {
            console.error('File input not found!');
            return;
        }
        
        // Upload button click handler
        uploadButton.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            console.log('Upload button clicked');
            fileInput.click();
        });
        
        // Upload area click handler
        uploadArea.addEventListener('click', function(e) {
            if (e.target === uploadButton || uploadButton.contains(e.target)) {
                return;
            }
            console.log('Upload area clicked');
            fileInput.click();
        });
        
        // File selection handler
        fileInput.addEventListener('change', function(e) {
            console.log('File selected');
            const file = e.target.files[0];
            if (file) {
                // Check file size (2MB limit)
                if (file.size > 2 * 1024 * 1024) {
                    alert('File size must be less than 2MB');
                    fileInput.value = '';
                    return;
                }
                
                // Check file type
                if (!file.type.match('image.*')) {
                    alert('Please select an image file');
                    fileInput.value = '';
                    return;
                }
                
                const reader = new FileReader();
                reader.onload = function(e) {
                    // Hide upload content and current image, show preview
                    uploadContent.style.display = 'none';
                    if (currentImageContainer) {
                        currentImageContainer.style.display = 'none';
                    }
                    imagePreview.style.display = 'block';
                    imagePreview.querySelector('img').src = e.target.result;
                }
                reader.readAsDataURL(file);
            }
        });
        
        // Remove image function
        window.removeImage = function() {
            fileInput.value = '';
            uploadContent.style.display = 'block';
            if (currentImageContainer) {
                currentImageContainer.style.display = 'block';
            }
            imagePreview.style.display = 'none';
        };
        
        // Change image function
        window.changeImage = function() {
            fileInput.click();
        };
        
        // Drag and drop
        uploadArea.addEventListener('dragover', function(e) {
            e.preventDefault();
            e.stopPropagation();
            this.classList.add('dragover');
        });
        
        uploadArea.addEventListener('dragleave', function(e) {
            e.preventDefault();
            e.stopPropagation();
            this.classList.remove('dragover');
        });
        
        uploadArea.addEventListener('drop', function(e) {
            e.preventDefault();
            e.stopPropagation();
            this.classList.remove('dragover');
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                fileInput.files = files;
                const event = new Event('change', { bubbles: true });
                fileInput.dispatchEvent(event);
            }
        });
    });
</script>

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
{% endblock %}