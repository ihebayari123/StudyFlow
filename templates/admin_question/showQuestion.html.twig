                                <td>{{ question.texte }}</td>
                                <td>{{ question.choixA }}</td>
                                <td>{{ question.choixB }}</td>
                                <td>{{ question.choixC }}</td>
                                <td>{{ question.choixD }}</td>
                                <td>{{ question.bonneReponse }}</td>
                                <td>{{ question.indice ?: 'N/A' }}</td>
                                <td>{{ question.quiz ? question.quiz.titre : 'N/A' }}</td>
