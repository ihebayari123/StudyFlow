<link rel="stylesheet" href="http://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="http://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<script>
document.addEventListener('DOMContentLoaded', function() {

    const header = document.querySelector('.header-area');
    if (header) {
        window.addEventListener('scroll', () => header.classList.toggle('scrolled', window.scrollY > 50));
    }

    document.querySelectorAll('.filter-btn').forEach(button => {
        button.addEventListener('click', function() {
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            this.classList.add('active');
            const filterType = this.dataset.type;
            document.querySelectorAll('.event-card').forEach(card => {
                card.style.display = filterType === 'all' || card.dataset.eventType === filterType ? 'block' : 'none';
            });
        });
    });

    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('keyup', function() {
            const v = this.value.toLowerCase();
            document.querySelectorAll('.event-card').forEach(card => {
                const t = card.querySelector('.event-title').textContent.toLowerCase();
                const d = card.querySelector('.event-description').textContent.toLowerCase();
                const c = card.querySelector('.event-category').textContent.toLowerCase();
                card.style.display = (t.includes(v) || d.includes(v) || c.includes(v)) ? 'block' : 'none';
            });
        });
    }

    document.querySelectorAll('.heart-icon').forEach(heart => {
        const id = heart.dataset.eventId;
        if (localStorage.getItem('heart_' + id) === 'liked') heart.classList.add('liked');
        heart.addEventListener('click', function(e) {
            e.stopPropagation();
            heart.classList.toggle('liked');
            localStorage[heart.classList.contains('liked') ? 'setItem' : 'removeItem']('heart_' + id, 'liked');
        });
    });

    const countdowns = document.querySelectorAll('.countdown');
    function updateCountdown() {
        const now = new Date().getTime();
        countdowns.forEach(cd => {
            if (!cd.dataset.date) return;
            const diff = new Date(cd.dataset.date).getTime() - now;
            if (diff > 0) {
                const d = Math.floor(diff / 86400000);
                const h = Math.floor((diff % 86400000) / 3600000);
                const m = Math.floor((diff % 3600000) / 60000);
                const s = Math.floor((diff % 60000) / 1000);
                cd.innerHTML = `<i class="bi bi-clock"></i> Starts in ${d}d ${h}h ${m}m ${s}s`;
            } else {
                cd.innerHTML = '<i class="bi bi-check-circle"></i> Event started';
                cd.style.background = 'rgba(76,175,80,0.1)';
                cd.style.color = '#4CAF50';
            }
        });
    }
    setInterval(updateCountdown, 1000);
    updateCountdown();

    const state = loadState();
    Object.keys(state).forEach(id => updateActionUI(id, state[id]));
    refreshFavCount();

    const wInput = document.getElementById('weatherCityInput');
    if (wInput) wInput.addEventListener('keypress', e => { if (e.key === 'Enter') fetchWeather(); });
});

/* ══════════════════════════════════════
   LIKE / DISLIKE / FAVORIS
══════════════════════════════════════ */
const STATE_KEY = 'sf_events_v2';
const FAV_KEY   = 'sf_favs_v2';

function loadState() { try { return JSON.parse(localStorage.getItem(STATE_KEY)) || {}; } catch { return {}; } }
function saveState(s) { localStorage.setItem(STATE_KEY, JSON.stringify(s)); }
function getEventData(id) { const s = loadState(); if (!s[id]) s[id] = { likes: 0, dislikes: 0, vote: null, fav: false }; return s[id]; }
function setEventData(id, d) { const s = loadState(); s[id] = d; saveState(s); }
function getFavMeta() { try { return JSON.parse(localStorage.getItem(FAV_KEY)) || {}; } catch { return {}; } }
function setFavMeta(m) { localStorage.setItem(FAV_KEY, JSON.stringify(m)); }

function updateActionUI(id, d) {
    const lb = document.getElementById(`like-btn-${id}`);
    if (!lb) return;
    document.getElementById(`like-count-${id}`).textContent    = d.likes;
    document.getElementById(`dislike-count-${id}`).textContent = d.dislikes;
    lb.classList.toggle('active', d.vote === 'like');
    document.getElementById(`dislike-btn-${id}`).classList.toggle('active', d.vote === 'dislike');
    const fb = document.getElementById(`fav-btn-${id}`);
    fb.classList.toggle('active', d.fav);
    fb.innerHTML = d.fav ? '⭐ Favori' : '☆ Favori';
}

function handleLike(id) {
    const d = getEventData(id);
    if (d.vote === 'like') { d.likes--; d.vote = null; }
    else { if (d.vote === 'dislike') d.dislikes--; d.likes++; d.vote = 'like'; }
    setEventData(id, d); updateActionUI(id, d);
}

function handleDislike(id) {
    const d = getEventData(id);
    if (d.vote === 'dislike') { d.dislikes--; d.vote = null; }
    else { if (d.vote === 'like') d.likes--; d.dislikes++; d.vote = 'dislike'; }
    setEventData(id, d); updateActionUI(id, d);
}

function handleFavorite(id, titre, type, date) {
    const d = getEventData(id); const m = getFavMeta();
    d.fav = !d.fav;
    if (d.fav) m[id] = { titre, type, date }; else delete m[id];
    setEventData(id, d); setFavMeta(m);
    updateActionUI(id, d); refreshFavCount(); renderFavList();
}

function refreshFavCount() {
    const el = document.getElementById('favCount');
    if (el) el.textContent = Object.keys(getFavMeta()).length;
}

function renderFavList() {
    const m = getFavMeta(); const ids = Object.keys(m);
    const el = document.getElementById('favList');
    const pc = document.getElementById('favPanelCount');
    if (pc) pc.textContent = ids.length;
    if (!ids.length) {
        el.innerHTML = `<div class="fav-empty-state"><div class="fav-empty-icon">✦</div><p>Aucun favori pour l'instant</p><small>Cliquez sur ☆ Favori pour ajouter des événements</small></div>`;
        return;
    }
    el.innerHTML = ids.map((id, i) => `
        <div class="fav-item" style="animation-delay:${i * 0.06}s">
            <div class="fav-item-type">${m[id].type}</div>
            <div class="fav-item-title">${m[id].titre}</div>
            <div class="fav-item-date"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>${m[id].date}</div>
            <button class="fav-remove-btn" onclick="handleFavorite(${id}, '${m[id].titre.replace(/'/g,"\\'")}', '${m[id].type}', '${m[id].date}')">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Retirer
            </button>
        </div>`).join('');
}

function toggleFavPanel() {
    const panel = document.getElementById('favoritesPanel');
    const overlay = document.getElementById('favOverlay');
    const isOpen = panel.classList.contains('open');
    if (isOpen) {
        panel.classList.remove('open'); overlay.classList.remove('visible');
        setTimeout(() => { overlay.style.display = 'none'; }, 350);
        document.body.style.overflow = '';
    } else {
        overlay.style.display = 'block';
        requestAnimationFrame(() => { overlay.classList.add('visible'); panel.classList.add('open'); });
        document.body.style.overflow = 'hidden'; renderFavList();
    }
}

/* ══════════════════════════════════════
   TRADUCTION
══════════════════════════════════════ */
async function translateText(text, targetLang) {
    if (!text || !text.trim()) return null;
    try {
        const res  = await fetch(`https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=fr|${targetLang}`);
        const data = await res.json();
        return data.responseStatus === 200 ? data.responseData.translatedText : null;
    } catch { return null; }
}

async function translateAll() {
    const lang = document.getElementById('langSelect').value;
    const spinner = document.getElementById('translateSpinner');
    const titles = document.querySelectorAll('.translatable-title');
    const descs  = document.querySelectorAll('.translatable-desc');
    const isRTL  = lang === 'ar';

    if (lang === 'fr') {
        titles.forEach(el => { el.textContent = el.dataset.original; el.style.direction = 'ltr'; el.style.textAlign = 'left'; });
        descs.forEach(el  => { const o = el.dataset.original; el.textContent = o.length > 150 ? o.slice(0,150)+'...' : o; el.style.direction = 'ltr'; el.style.textAlign = 'left'; });
        return;
    }

    spinner.style.display = 'block';
    titles.forEach(el => el.classList.add('translating'));
    descs.forEach(el  => el.classList.add('translating'));

    const titleP = Array.from(titles).map(el =>
        translateText(el.dataset.original, lang).then(t => {
            if (t) { el.textContent = t; el.style.direction = isRTL ? 'rtl' : 'ltr'; el.style.textAlign = isRTL ? 'right' : 'left'; }
            el.classList.remove('translating'); el.classList.add('translated');
        })
    );

    const descP = Array.from(descs).map(el => {
        const o = el.dataset.original;
        return translateText(o.length > 150 ? o.slice(0,150) : o, lang).then(t => {
            if (t) { el.textContent = t.length > 150 ? t.slice(0,150)+'...' : t; el.style.direction = isRTL ? 'rtl' : 'ltr'; el.style.textAlign = isRTL ? 'right' : 'left'; }
            el.classList.remove('translating'); el.classList.add('translated');
        });
    });

    await Promise.all([...titleP, ...descP]);
    spinner.style.display = 'none';
}

/* ══════════════════════════════════════
   MÉTÉO
══════════════════════════════════════ */
function fetchWeather() {
    const city = document.getElementById('weatherCityInput').value.trim();
    if (!city) return;
    const result = document.getElementById('weatherResult');
    const error  = document.getElementById('weatherError');
    const btn    = document.querySelector('.weather-search-bar button');
    result.style.display = 'none'; error.style.display = 'none';
    btn.textContent = '⏳ Chargement...'; btn.disabled = true;
    fetch(`/events/weather?lieu=${encodeURIComponent(city)}`)
        .then(r => r.json())
        .then(data => {
            btn.textContent = '🌤 Voir la météo'; btn.disabled = false;
            if (data.error) { error.style.display = 'block'; return; }
            document.getElementById('w-icon').textContent     = data.icon;
            document.getElementById('w-temp').textContent     = data.temperature;
            document.getElementById('w-desc').textContent     = data.description;
            document.getElementById('w-wind').textContent     = data.windspeed;
            document.getElementById('w-humidity').textContent = data.humidity;
            document.getElementById('w-city').textContent     = '📍 ' + data.city;
            result.style.display = 'flex';
        })
        .catch(() => { btn.textContent = '🌤 Voir la météo'; btn.disabled = false; error.style.display = 'block'; });
}

/* ══════════════════════════════════════
   ✅ GÉNÉRATEUR D'AFFICHE (HTML Canvas)
   CORRECTION CORS : l'image est chargée via
   la route Symfony /events/image-base64?filename=xxx
   qui lit public/uploads/xxx et retourne du base64
══════════════════════════════════════ */
let currentPosterData = {};

function openPosterModal(titre, type, date, description, imageFilename) {
    currentPosterData = { titre, type, date, description, imageFilename };
    document.getElementById('posterModal').classList.add('open');
    document.body.style.overflow = 'hidden';
    drawPoster(titre, type, date, description, imageFilename);
}

function closePosterModal(e) {
    if (e && e.target !== document.getElementById('posterModal') && !e.target.classList.contains('poster-modal-close')) return;
    document.getElementById('posterModal').classList.remove('open');
    document.body.style.overflow = '';
}

function drawPoster(titre, type, date, description, imageFilename) {
    const canvas = document.getElementById('posterCanvas');
    const ctx    = canvas.getContext('2d');
    const W = 800, H = 500;
    canvas.width = W; canvas.height = H;

    const typeColors = {
        'EDUCATION' : ['#667eea', '#764ba2'],
        'CULTURE'   : ['#f093fb', '#f5576c'],
        'SPORT'     : ['#4facfe', '#00f2fe'],
        'BIEN-ETRE' : ['#43e97b', '#38f9d7'],
        'TECH'      : ['#fa709a', '#fee140'],
        'HACKATHON' : ['#f7971e', '#ffd200'],
        'FORMATION' : ['#11998e', '#38ef7d'],
        'WORKSHOP'  : ['#ee0979', '#ff6a00'],
    };
    const colors = typeColors[type] || ['#667eea', '#764ba2'];

    const drawContent = (img) => {
        // Fond dégradé
        const grad = ctx.createLinearGradient(0, 0, W, H);
        grad.addColorStop(0, colors[0]);
        grad.addColorStop(1, colors[1]);
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, W, H);

        // ✅ Image en fond couvrant toute la canvas (object-fit: cover)
        if (img) {
            const scale = Math.max(W / img.width, H / img.height);
            const iw = img.width  * scale;
            const ih = img.height * scale;
            const ix = (W - iw) / 2;
            const iy = (H - ih) / 2;
            ctx.save();
            ctx.globalAlpha = 0.38;
            ctx.drawImage(img, ix, iy, iw, ih);
            ctx.restore();
        }

        // Overlay sombre pour lisibilité
        ctx.fillStyle = 'rgba(0,0,0,0.50)';
        ctx.fillRect(0, 0, W, H);

        // Bande décorative gauche
        ctx.fillStyle = 'rgba(255,255,255,0.08)';
        ctx.fillRect(0, 0, 8, H);

        // Badge TYPE
        ctx.fillStyle = 'rgba(255,255,255,0.2)';
        roundRect(ctx, 40, 40, 140, 36, 18);
        ctx.fill();
        ctx.fillStyle = 'white';
        ctx.font = 'bold 14px Segoe UI';
        ctx.textAlign = 'left';
        ctx.fillText('📌 ' + type, 58, 63);

        // Date
        ctx.fillStyle = 'rgba(255,255,255,0.7)';
        ctx.font = '15px Segoe UI';
        ctx.textAlign = 'right';
        ctx.fillText('📅 ' + date, W - 40, 63);

        // Titre principal
        ctx.fillStyle = 'white';
        ctx.font = 'bold 42px Segoe UI';
        ctx.textAlign = 'left';
        wrapText(ctx, titre, 40, 170, W - 80, 52);

        // Ligne séparatrice
        ctx.strokeStyle = 'rgba(255,255,255,0.3)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(40, 270);
        ctx.lineTo(W - 40, 270);
        ctx.stroke();

        // Description
        ctx.fillStyle = 'rgba(255,255,255,0.8)';
        ctx.font = '16px Segoe UI';
        wrapText(ctx, description || '', 40, 310, W - 80, 24, 3);

        // Footer branding
        ctx.fillStyle = 'rgba(255,255,255,0.15)';
        ctx.fillRect(0, H - 60, W, 60);
        ctx.fillStyle = 'rgba(255,255,255,0.9)';
        ctx.font = 'bold 16px Segoe UI';
        ctx.textAlign = 'center';
        ctx.fillText('✦ StudyFlow Events', W / 2, H - 28);

        // Cercles décoratifs
        ctx.beginPath();
        ctx.arc(W - 80, H - 180, 100, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.04)';
        ctx.fill();
        ctx.beginPath();
        ctx.arc(W - 60, H - 160, 60, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.06)';
        ctx.fill();
    };

    // ✅ Charger l'image via la route Symfony /events/image-base64?filename=xxx
    // → Symfony lit public/uploads/xxx et retourne du base64 → zéro CORS
    if (imageFilename && imageFilename.trim() !== '') {
        fetch(`/events/image-base64?filename=${encodeURIComponent(imageFilename)}`)
            .then(r => r.json())
            .then(data => {
                if (data.base64) {
                    const img = new Image();
                    img.onload  = () => drawContent(img);
                    img.onerror = () => drawContent(null);
                    img.src = data.base64; // base64 → pas de CORS
                } else {
                    drawContent(null);
                }
            })
            .catch(() => drawContent(null));
    } else {
        drawContent(null);
    }
}

function wrapText(ctx, text, x, y, maxWidth, lineHeight, maxLines = 4) {
    if (!text) return;
    const words = text.split(' ');
    let line = '', count = 0;
    for (let i = 0; i < words.length; i++) {
        const test = line + words[i] + ' ';
        if (ctx.measureText(test).width > maxWidth && i > 0) {
            ctx.fillText(line.trim(), x, y);
            line = words[i] + ' ';
            y += lineHeight; count++;
            if (count >= maxLines) { ctx.fillText('...', x, y); return; }
        } else { line = test; }
    }
    ctx.fillText(line.trim(), x, y);
}

function roundRect(ctx, x, y, w, h, r) {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.lineTo(x + w - r, y);
    ctx.quadraticCurveTo(x + w, y, x + w, y + r);
    ctx.lineTo(x + w, y + h - r);
    ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    ctx.lineTo(x + r, y + h);
    ctx.quadraticCurveTo(x, y + h, x, y + h - r);
    ctx.lineTo(x, y + r);
    ctx.quadraticCurveTo(x, y, x + r, y);
    ctx.closePath();
}

function downloadPoster() {
    const canvas = document.getElementById('posterCanvas');
    const link   = document.createElement('a');
    const titre  = currentPosterData.titre || 'event';
    link.download = `affiche-${titre.toLowerCase().replace(/\s+/g, '-')}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
}
</script>

