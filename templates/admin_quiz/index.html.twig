{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}

<div class="admin-main-content">
    <div class="container-fluid py-4">

        <div class="mb-4">
            <h2 class="fw-bold">
                📊 Tableau de bord des statistiques
            </h2>
            <p class="text-muted mb-0">
                Aperçu général des performances de tous les quiz
            </p>
        </div>

        <div class="row">
            {% for quiz in quizzes %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">{{ quiz.titre }}</h5>
                            <p class="card-text text-muted small">{{ quiz.description|slice(0, 100) }}...</p>
                            
                            <hr>
                            
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tentatives:</span>
                                <span class="fw-bold">{{ globalStats[quiz.id].total_attempts ?? 0 }}</span>
                            </div>
                            
                            <div class="d-flex justify-content-between mb-2">
                                <span>Points moyens:</span>
                                <span class="fw-bold">{{ globalStats[quiz.id].average_points ?? 0 }}</span>
                            </div>
                            
                            <div class="d-flex justify-content-between mb-3">
                                <span>Taux de réussite:</span>
                                <span class="fw-bold text-success">{{ globalStats[quiz.id].success_rate ?? 0 }}%</span>
                            </div>
                            
                            <a href="{{ path('admin_quiz_statistics_list') }}#quiz-{{ quiz.id }}" 
                               class="btn btn-outline-primary w-100">
                                Voir les détails ←
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info">
                        Aucun quiz disponible pour le moment
                    </div>
                </div>
            {% endfor %}
        </div>

    </div>
</div>

<style>
.admin-main-content {
    margin-right: 280px;
    margin-top: 80px;
    padding: 30px;
    min-height: calc(100vh - 80px);
    background-color: #f8f9fa;
}

.card {
    border-radius: 15px;
    transition: all 0.3s;
}

.card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
}
</style>

{% endblock %}