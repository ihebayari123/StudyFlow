{# templates/admin/user_search_test.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Test Natural Search{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1>🔍 Test Natural Language Search</h1>
    
    <div class="card">
        <div class="card-body">
            <div class="mb-3">
                <label for="query" class="form-label">Requête:</label>
                <input type="text" id="query" class="form-control" 
                       value="admins with unverified emails">
            </div>
            
            <button onclick="testSearch()" class="btn btn-primary">
                Tester
            </button>
            
            <hr>
            
            <h5>Résultat:</h5>
            <pre id="result" style="background: #f5f5f5; padding: 15px; border-radius: 5px;"></pre>
        </div>
    </div>
</div>

<script>
async function testSearch() {
    const query = document.getElementById('query').value;
    
    const response = await fetch('/admin/users/natural-search', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({query: query})
    });
    
    const data = await response.json();
    document.getElementById('result').textContent = JSON.stringify(data, null, 2);
}
</script>
{% endblock %}