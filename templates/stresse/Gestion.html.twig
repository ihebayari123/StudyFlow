            }

            .progress-ring {
                position: absolute;
                top: 15px;
                right: 15px;
                width: 50px;
                height: 50px;
            }

            .circle-bg {
                fill: none;
                stroke: #e2e8f0;
                stroke-width: 3;
            }

            .circle-progress {
                fill: none;
                stroke: #667eea;
                stroke-width: 3;
                stroke-linecap: round;
                transform: rotate(-90deg);
                transform-origin: 50% 50%;
