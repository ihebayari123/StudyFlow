                padding: 4px 8px;
                border-radius: 5px;
                font-size: 0.7rem;
                color: #64748b;
            }

            /* Erreurs Grid */
            .erreurs-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 20px;
                margin-top: 30px;
            }

            .erreur-card {
                background: white;
                border-radius: 15px;
                padding: 25px;
                display: flex;
                gap: 15px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
                border-left: 4px solid #ef4444;
