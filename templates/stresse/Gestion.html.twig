            .profil-title {
                color: #1a1a1a;
                font-size: 1.2rem;
                font-weight: 700;
                margin: 0;
            }

            .profil-conseils {
                list-style: none;
                padding: 0;
            }

            .profil-conseils li {
                padding: 12px 0;
                padding-left: 25px;
                position: relative;
                border-bottom: 1px solid #f1f5f9;
                color: #555;
                font-size: 0.9rem;
            }

            .profil-conseils li:last-child {
                border-bottom: none;
            }

            .profil-conseils li::before {
                content: '→';
