                height: 35px;
                background: #ef4444;
                color: white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 800;
                font-size: 1.2rem;
                flex-shrink: 0;
            }

            .erreur-title {
                color: #1a1a1a;
                font-size: 1.1rem;
                font-weight: 700;
                margin-bottom: 10px;
            }

            .erreur-description {
                color: #666;
                font-size: 0.9rem;
                margin-bottom: 10px;
                line-height: 1.5;
