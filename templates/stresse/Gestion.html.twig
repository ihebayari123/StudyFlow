                flex-wrap: wrap;
            }

            .btn-primary {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                padding: 15px 35px;
                background: white;
                color: #667eea;
                text-decoration: none;
                border-radius: 30px;
                font-weight: 600;
                font-size: 1.1rem;
                transition: all 0.3s ease;
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }

            .btn-primary:hover {
                transform: scale(1.05);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
                color: #667eea;
            }

            .btn-secondary {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                padding: 15px 35px;
                background: transparent;
                color: white;
                text-decoration: none;
                border-radius: 30px;
                font-weight: 600;
                font-size: 1.1rem;
                border: 2px solid white;
                transition: all 0.3s ease;
            }

            .btn-secondary:hover {
                background: white;
                color: #667eea;
                transform: scale(1.05);
            }

            /* Responsive */
            @media (max-width: 1024px) {
                .planning-container {
                    grid-template-columns: repeat(4, 1fr);
                }
            }

            @media (max-width: 768px) {
                .time-management-section {
                    padding: 100px 15px 40px 15px;
                }

                .header-with-button {
                    flex-direction: column;
                    text-align: center;
                }

                .section-title {
                    font-size: 2.2rem;
                    justify-content: center;
                }

                .section-subtitle {
                    font-size: 1.6rem;
                }

                .description-text,
                .section-description {
                    font-size: 1rem;
                }

                .stats-grid {
                    grid-template-columns: 1fr;
                }

                .quick-nav {
                    flex-direction: column;
                    align-items: stretch;
                }

                .quick-nav-item {
                    justify-content: center;
                }

                .cards-grid,
                .modeles-grid,
                .outils-grid,
                .erreurs-grid,
                .profils-grid,
                .indicateurs-grid {
                    grid-template-columns: 1fr;
                }

                .planning-container {
                    grid-template-columns: repeat(2, 1fr);
                }

                .content-section {
                    padding: 30px 20px;
                }

                .cta-section {
                    padding: 30px 20px;
                }

                .cta-section h3 {
                    font-size: 1.5rem;
                }

                .cta-buttons {
                    flex-direction: column;
                    align-items: center;
                }

                .btn-primary,
                .btn-secondary {
                    width: 100%;
                    justify-content: center;
                }
            }

            @media (max-width: 480px) {
                .section-title {
                    font-size: 1.8rem;
                }

                .header-icon .emoji {
                    font-size: 3rem;
                }

                .planning-container {
                    grid-template-columns: 1fr;
                }

                .erreur-card {
                    flex-direction: column;
                    align-items: center;
                    text-align: center;
                }

                .indicateur-card {
                    flex-direction: column;
                    text-align: center;
                }

                .indicateur-target {
                    justify-content: center;
                }
            }
        </style>
    {% endblock %}

    <script>
        function toggleDetails(id) {
            const card = document.querySelector(`[data-id="${id}"]`);
            const btn = card.querySelector('.card-btn');
            const steps = card.querySelector('.card-steps');
            const avantages = card.querySelector('.card-avantages');
            const conseils = card.querySelector('.card-conseils');
            
            if (btn.innerHTML.includes('En savoir plus')) {
                btn.innerHTML = 'Réduire <i class="fas fa-arrow-up"></i>';
                steps.style.display = 'block';
                avantages.style.display = 'block';
                conseils.style.display = 'block';
            } else {
                btn.innerHTML = 'En savoir plus <i class="fas fa-arrow-right"></i>';
                steps.style.display = 'none';
                avantages.style.display = 'none';
                conseils.style.display = 'none';
            }
        }

        // Initialisation : cacher les détails
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.card-steps, .card-avantages, .card-conseils').forEach(el => {
                el.style.display = 'none';
            });
        });
    </script>
{% endblock %}