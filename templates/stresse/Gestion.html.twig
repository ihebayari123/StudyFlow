            }

            .outil-categorie {
                display: inline-block;
                background: #f1f5f9;
                padding: 4px 12px;
                border-radius: 20px;
                font-size: 0.75rem;
                color: #64748b;
                margin-bottom: 10px;
            }

            .outil-title {
                color: #1a1a1a;
                font-size: 1.2rem;
                font-weight: 700;
                margin-bottom: 10px;
            }

            .outil-description {
                color: #666;
                font-size: 0.9rem;
                margin-bottom: 15px;
            }

            .outil-features {
