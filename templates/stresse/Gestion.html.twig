            .modele-conseils {
                background: #f8f9fa;
                padding: 15px;
                border-radius: 10px;
            }

            .modele-conseils h4 {
                color: #333;
                font-size: 1rem;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .modele-conseils ul {
