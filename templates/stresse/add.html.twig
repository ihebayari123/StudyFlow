{# templates/stresse/add.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Nouveau Sondage Stress{% endblock %}

{% block body %}
<!-- ======= Header ======= -->
{% block header %}
{% include 'home/navbar.html.twig' %}
{% endblock %}

<div class="courses-section">
    <div class="container">
        <div class="header-with-button">
            <h1 class="section-title">Nouveau Sondage Stress</h1>
            <a href="{{ path('app_showstresse') }}" class="add-course-btn">
                <i class="fas fa-arrow-left"></i> Retour aux Sondages
            </a>
        </div>

        <!-- Formulaire dans une carte -->
        <div class="course-card form-card">
            <div class="card-body p-4 p-lg-5">
                {{ form_start(form, {'attr': {'class': 'needs-validation form-content', 'novalidate': 'novalidate'}}) }}
                
                <!-- Section Informations Générales -->
                <div class="form-section mb-5">
                    <div class="section-header mb-4">
                        <h4 class="section-title">
                            <i class="fas fa-calendar-alt me-2"></i>
                            Informations du Sondage
                        </h4>
                        <div class="section-divider"></div>
                    </div>
                    
                    <div class="row mb-4">
                        <!-- Date du Sondage -->
                        <div class="col-md-6">
                            {{ form_label(form.date, 'Date du Sondage', {
                                'label_attr': {'class': 'form-label fw-semibold form-label-custom'}
                            }) }}
                            <div class="input-group">
                                <span class="input-group-text form-input-icon">
                                    <i class="fas fa-calendar-check"></i>
                                </span>
                                {{ form_widget(form.date, {
                                    'attr': {
                                        'class': 'form-control form-input',
                                        'placeholder': 'Sélectionnez la date'
                                    }
                                }) }}
                            </div>
                            <div class="form-text text-muted small mt-1">
                                <i class="fas fa-info-circle me-1"></i>
                                Date du relevé de stress
                            </div>
                            {{ form_errors(form.date) }}
                        </div>
                        
                        <!-- Utilisateur -->
                        <div class="col-md-6">
                            {{ form_label(form.user, 'Utilisateur', {
                                'label_attr': {'class': 'form-label fw-semibold form-label-custom'}
                            }) }}
                            <div class="input-group">
                                <span class="input-group-text form-input-icon">
                                    <i class="fas fa-user"></i>
                                </span>
                                {{ form_widget(form.user, {
                                    'attr': {
                                        'class': 'form-select form-select-custom',
                                        'placeholder': 'Sélectionnez l\'utilisateur'
                                    }
                                }) }}
                            </div>
                            <div class="form-text text-muted small mt-1">
                                <i class="fas fa-info-circle me-1"></i>
                                Personne concernée par le sondage
                            </div>
                            {{ form_errors(form.user) }}
                        </div>
                    </div>
                </div>

                <!-- Section Évaluation du Stress -->
                <div class="form-section mb-5">
                    <div class="section-header mb-4">
                        <h4 class="section-title">
                            <i class="fas fa-chart-line me-2"></i>
                            Évaluation du Stress
                        </h4>
                        <div class="section-divider"></div>
                    </div>
                    
                    <div class="row">
                        <!-- Heures de sommeil -->
                        <div class="col-md-6 mb-4">
                            {{ form_label(form.sleepHours, 'Heures de Sommeil', {
                                'label_attr': {'class': 'form-label fw-semibold form-label-custom'}
                            }) }}
                            <div class="input-group">
                                <span class="input-group-text form-input-icon">
                                    <i class="fas fa-moon"></i>
                                </span>
                                {{ form_widget(form.sleepHours, {
                                    'attr': {
                                        'class': 'form-control form-input',
                                        'placeholder': 'Ex: 7.5',
                                        'step': '0.5',
                                        'min': '0',
                                        'max': '24'
                                    }
                                }) }}
                                <span class="input-group-text form-input-icon-end bg-light text-dark border-2 border-start-0">
                                    heures
                                </span>
                            </div>
                            <div class="form-text text-muted small mt-1">
                                <i class="fas fa-info-circle me-1"></i>
                                Quantité de sommeil par nuit (0-24 heures)
                            </div>
                            {{ form_errors(form.sleepHours) }}
                        </div>
                        
                        <!-- Heures d'étude -->
                        <div class="col-md-6 mb-4">
                            {{ form_label(form.studyHours, 'Heures d\'Étude', {
                                'label_attr': {'class': 'form-label fw-semibold form-label-custom'}
                            }) }}
                            <div class="input-group">
                                <span class="input-group-text form-input-icon">
                                    <i class="fas fa-graduation-cap"></i>
                                </span>
                                {{ form_widget(form.studyHours, {
                                    'attr': {
                                        'class': 'form-control form-input',
                                        'placeholder': 'Ex: 6',
                                        'step': '0.5',
                                        'min': '0',
                                        'max': '24'
                                    }
                                }) }}
                                <span class="input-group-text form-input-icon-end bg-light text-dark border-2 border-start-0">
                                    heures
                                </span>
                            </div>
                            <div class="form-text text-muted small mt-1">
                                <i class="fas fa-info-circle me-1"></i>
                                Temps consacré aux études par jour
                            </div>
                            {{ form_errors(form.studyHours) }}
                        </div>
                    </div>
                </div>

                <!-- Section Recommandations -->
                <div class="form-section mb-5">
                    <div class="section-header mb-4">
                        <h4 class="section-title">
                            <i class="fas fa-info-circle me-2"></i>
                            Recommandations
                        </h4>
                        <div class="section-divider"></div>
                    </div>
                    
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="recommendation-card">
                                <div class="recommendation-icon sleep-icon">
                                    <i class="fas fa-bed"></i>
                                </div>
                                <h5>Sommeil optimal</h5>
                                <p>7-9 heures par nuit</p>
                                <span class="badge bg-success bg-opacity-10 text-success">
                                    <i class="fas fa-check-circle me-1"></i>Recommandé
                                </span>
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="recommendation-card">
                                <div class="recommendation-icon study-icon">
                                    <i class="fas fa-book"></i>
                                </div>
                                <h5>Études équilibrées</h5>
                                <p>4-6 heures par jour</p>
                                <span class="badge bg-info bg-opacity-10 text-info">
                                    <i class="fas fa-clock me-1"></i>Modéré
                                </span>
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="recommendation-card">
                                <div class="recommendation-icon stress-icon">
                                    <i class="fas fa-heart"></i>
                                </div>
                                <h5>Gestion du stress</h5>
                                <p>Pauses régulières</p>
                                <span class="badge bg-warning bg-opacity-10 text-warning">
                                    <i class="fas fa-exclamation-circle me-1"></i>À surveiller
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Boutons d'action -->
                <div class="form-actions mt-5 pt-4 border-top">
                    <div class="d-flex justify-content-between align-items-center">
                        <button type="reset" class="btn btn-outline-primary filter-btn">
                            <i class="fas fa-redo me-2"></i>
                            Réinitialiser
                        </button>
                        <div class="d-flex gap-3">
                            <a href="{{ path('app_studyflow_score') }}" class="btn filter-btn">
                                <i class="fas fa-times me-2"></i>
                                Annuler
                            </a>
                            {{ form_widget(form.enregistrer, {
                                'label': 'Enregistrer le Sondage',
                                'attr': {
                                    'class': 'add-course-btn'
                                }
                            }) }}
                        </div>
                    </div>
                </div>

                {{ form_end(form) }}
            </div>
        </div>

        <!-- Informations supplémentaires -->
        <div class="course-card info-card mt-4">
            <div class="course-content">
                <div class="d-flex align-items-center">
                    <i class="fas fa-shield-alt fa-2x me-3" style="color: #667eea;"></i>
                    <div>
                        <h3 class="course-title mb-2">Confidentialité des données</h3>
                        <p class="course-author mb-2">
                            <i class="fas fa-lock me-2"></i>
                            Les informations de stress sont strictement confidentielles.
                        </p>
                        <p class="course-author mb-0">
                            <i class="fas fa-chart-line me-2"></i>
                            Ces données permettent d'améliorer le bien-être des étudiants.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }

    /* Keep navbar text white */
    .header-area {
        background: rgba(0, 0, 0, 0.3) !important;
        backdrop-filter: blur(10px);
    }

    .header-area .logo h1,
    .header-area .nav a,
    .header-area .menu-trigger span,
    nav, .navbar, nav *, .navbar *, .nav-link {
        color: white !important;
    }

    .courses-section {
        padding: 120px 20px 60px 20px;
        background-color: transparent;
        min-height: 100vh;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Header with Button */
    .header-with-button {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 50px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .section-title {
        font-size: 3rem;
        font-weight: 700;
        color: #ffffff;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        margin: 0;
    }

    /* Add Course Button */
    .add-course-btn {
        padding: 15px 35px;
        background: white;
        color: #667eea;
        text-decoration: none;
        border-radius: 30px;
        font-weight: 600;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 5px 20px rgba(255, 255, 255, 0.3);
        margin-top: 30px;
        border: none;
        cursor: pointer;
    }

    .add-course-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(255, 255, 255, 0.4);
        background: linear-gradient(135deg, #ffffff 0%, #f0f0ff 100%);
        color: #667eea;
        text-decoration: none;
    }

    .add-course-btn i {
        font-size: 1.3rem;
    }

    /* Filter Buttons */
    .filter-btn {
        padding: 12px 30px;
        border: none;
        background-color: rgba(255, 255, 255, 0.2);
        color: white;
        border-radius: 30px;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 500;
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255, 255, 255, 0.3);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .filter-btn:hover,
    .filter-btn.active {
        background-color: white;
        color: #667eea;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 255, 255, 0.3);
        text-decoration: none;
    }

    /* Form Cards */
    .form-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        margin-bottom: 30px;
    }

    .form-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    }

    .info-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    /* Form Content */
    .form-content {
        padding: 20px;
    }

    /* Sections du formulaire */
    .form-section {
        position: relative;
    }

    .section-header {
        position: relative;
        margin-bottom: 30px;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #667eea;
        display: flex;
        align-items: center;
        margin-bottom: 10px;
    }

    .section-divider {
        height: 2px;
        background: linear-gradient(90deg, #667eea 0%, transparent 100%);
        opacity: 0.3;
        margin-top: 10px;
    }

    /* Labels */
    .form-label-custom {
        color: #374151;
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
    }

    .form-label-custom::after {
        content: ' *';
        color: #f44336;
    }

    /* Champs de formulaire */
    .form-input, .form-select-custom, .form-textarea {
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        background: #f8fafc;
        width: 100%;
    }

    .form-input:focus, .form-select-custom:focus, .form-textarea:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        background: white;
        outline: none;
    }

    .form-input-icon {
        background: #e8f2ff;
        border: 2px solid #e5e7eb;
        border-right: none;
        color: #667eea;
        font-size: 1rem;
        border-radius: 10px 0 0 10px;
    }

    .form-input-icon-end {
        border: 2px solid #e5e7eb;
        border-left: none;
        border-radius: 0 10px 10px 0;
        background: #f8fafc;
        color: #6b7280;
    }

    .form-textarea {
        resize: vertical;
        min-height: 100px;
    }

    /* Groupes d'input */
    .input-group:focus-within .form-input-icon {
        border-color: #667eea;
        background: #667eea;
        color: white;
    }

    .input-group:focus-within .form-input-icon-end {
        border-color: #667eea;
        background: #e8f2ff;
        color: #667eea;
    }

    /* Messages d'erreur */
    .form-error {
        color: #f44336;
        font-size: 0.875rem;
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Textes d'aide */
    .form-text {
        font-size: 0.85rem;
        color: #6b7280;
        margin-top: 5px;
    }

    /* Recommandation Cards */
    .recommendation-card {
        background: linear-gradient(135deg, #f8f9ff 0%, #ffffff 100%);
        border-radius: 15px;
        padding: 20px;
        text-align: center;
        border: 2px solid rgba(102, 126, 234, 0.1);
        transition: all 0.3s ease;
        height: 100%;
    }

    .recommendation-card:hover {
        transform: translateY(-5px);
        border-color: rgba(102, 126, 234, 0.3);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.1);
    }

    .recommendation-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 1.8rem;
        transition: all 0.3s ease;
    }

    .sleep-icon {
        background: linear-gradient(135deg, #667eea20 0%, #667eea40 100%);
        color: #667eea;
    }

    .study-icon {
        background: linear-gradient(135deg, #4CAF5020 0%, #4CAF5040 100%);
        color: #4CAF50;
    }

    .stress-icon {
        background: linear-gradient(135deg, #FF980020 0%, #FF980040 100%);
        color: #FF9800;
    }

    .recommendation-card h5 {
        font-size: 1.1rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 10px;
    }

    .recommendation-card p {
        color: #6b7280;
        font-size: 0.95rem;
        margin-bottom: 15px;
    }

    .badge {
        padding: 8px 15px;
        font-weight: 500;
        border-radius: 20px;
        font-size: 0.85rem;
    }

    /* Actions du formulaire */
    .form-actions {
        border-top: 2px solid #e5e7eb;
    }

    /* Course Content (pour la carte info) */
    .course-content {
        padding: 25px 30px 30px;
        background: white;
    }

    .course-author {
        color: #7b68ee;
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .course-title {
        color: #1a1a1a;
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.4;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .header-with-button {
            flex-direction: column;
            text-align: center;
        }

        .section-title {
            font-size: 2rem;
        }

        .add-course-btn {
            width: 100%;
            justify-content: center;
            margin-top: 20px;
        }

        .filter-btn {
            width: 100%;
            margin-bottom: 10px;
        }

        .form-actions .d-flex {
            flex-direction: column;
            gap: 15px;
        }
        
        .form-actions .d-flex > div,
        .form-actions .d-flex > a,
        .form-actions .d-flex > button {
            width: 100%;
        }

        .recommendation-card {
            margin-bottom: 15px;
        }
    }

    /* Animations */
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .form-section {
        animation: fadeIn 0.5s ease-out;
    }

    .form-section:nth-child(1) { animation-delay: 0.1s; }
    .form-section:nth-child(2) { animation-delay: 0.2s; }
    .form-section:nth-child(3) { animation-delay: 0.3s; }
</style>

<!-- Inclure FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<!-- Inclure les styles pour les sélecteurs de date -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

<script>
    // Initialiser le sélecteur de date
    document.addEventListener('DOMContentLoaded', function() {
        const dateField = document.querySelector('#{{ form.date.vars.id }}');
        if (dateField) {
            flatpickr(dateField, {
                enableTime: false,
                dateFormat: 'Y-m-d',
                locale: 'fr',
                maxDate: 'today',
                defaultDate: 'today',
                disableMobile: true,
                static: true
            });
        }
    });

    // Validation personnalisée
    const form = document.querySelector('form.needs-validation');
    if (form) {
        form.addEventListener('submit', function(event) {
            if (!this.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
                
                // Ajouter la classe was-validated pour afficher les messages
                this.classList.add('was-validated');
                
                // Faire défiler jusqu'au premier champ invalide
                const firstInvalid = this.querySelector(':invalid');
                if (firstInvalid) {
                    firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    firstInvalid.focus();
                }
            }
        }, false);
    }

    // Validation des heures
    function validateHours(input) {
        const value = parseFloat(input.value);
        if (value < 0) input.value = 0;
        if (value > 24) input.value = 24;
    }

    const sleepHours = document.querySelector('#{{ form.sleepHours.vars.id }}');
    const studyHours = document.querySelector('#{{ form.studyHours.vars.id }}');
    
    if (sleepHours) {
        sleepHours.addEventListener('change', function() { validateHours(this); });
    }
    if (studyHours) {
        studyHours.addEventListener('change', function() { validateHours(this); });
    }
</script>
{% endblock %}