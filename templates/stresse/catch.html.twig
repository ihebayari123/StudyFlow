                transition: all 0.3s ease;
                text-decoration: none;
                box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);
            }

            .btn-action i:last-child {
                opacity: 0;
                transform: translateX(-10px);
                transition: all 0.3s ease;
            }

            .btn-action:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
