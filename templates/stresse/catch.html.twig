{% extends 'base.html.twig' %}

{% block title %}Agenda des Cours - StudyFlow{% endblock %}

{% block body %}
    <!-- Header -->
    {% block header %}
        {% include 'home/navbar.html.twig' %}
    {% endblock %}

    <!-- Main Content -->
    <div class="agenda-section">
        <div class="container">
            <!-- Page Header -->
            <div class="header-with-button">
                <h1 class="section-title">📅 Agenda des Cours</h1>
                <div class="header-icon">
                    <span class="emoji">⏰</span>
                </div>
            </div>

            <!-- Page Description -->
            <div class="description-section">
                <p class="description-text">
                    Votre agenda personnalisé avec notifications pour chaque cours
                </p>
            </div>

            <!-- Quick Stats -->
            <div class="quick-stats">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-book-open"></i>
                    </div>
                    <div class="stat-content">
                        <span class="stat-value">{{ coursAVoir|length }}</span>
                        <span class="stat-label">Cours à voir</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-bell"></i>
                    </div>
                    <div class="stat-content">
                        <span class="stat-value">{{ notifications|length }}</span>
                        <span class="stat-label">Notifications</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-calendar-day"></i>
                    </div>
                    <div class="stat-content">
                        <span class="stat-value">{{ "now"|date("d F") }}</span>
                        <span class="stat-label">Aujourd'hui</span>
                    </div>
                </div>
            </div>

            <!-- Daily Tip Card -->
            <div class="daily-tip-card">
                <div class="tip-label">
                    <i class="fas fa-lightbulb"></i> Conseil anti-stress du jour
                </div>
                <p class="tip-text">Prenez 5 minutes entre chaque cours pour respirer profondément et vous recentrer.</p>
            </div>

            <!-- Notifications Section -->
            {% if notifications|length > 0 %}
            <div class="notifications-section">
                <div class="section-header">
                    <h2 class="section-subtitle">
                        <i class="fas fa-bell"></i> Notifications
                    </h2>
                </div>

                <div class="notifications-grid">
                    {% for notification in notifications %}
                        <div class="notification-card notification-{{ notification.type }}">
                            <div class="notification-header">
                                <div class="notification-icon">
                                    {% if notification.type == 'en_cours' %}
                                        <i class="fas fa-play-circle"></i>
                                    {% elseif notification.type == 'imminent' %}
                                        <i class="fas fa-exclamation-circle"></i>
                                    {% elseif notification.type == 'proche' %}
                                        <i class="fas fa-clock"></i>
                                    {% else %}
                                        <i class="fas fa-calendar-alt"></i>
                                    {% endif %}
                                </div>
                                <span class="notification-badge badge-{{ notification.priorite }}">{{ notification.priorite }}</span>
                            </div>
                            
                            <div class="notification-body">
                                <h3 class="notification-title">{{ notification.matiere }}</h3>
                                <p class="notification-message">{{ notification.message }}</p>
                                <div class="notification-meta">
                                    <span><i class="far fa-calendar"></i> {{ notification.jour }}</span>
                                    <span><i class="far fa-clock"></i> {{ notification.heureDebut }} - {{ notification.heureFin }}</span>
                                </div>
                            </div>
                            
                            {% if notification.conseils|length > 0 %}
                            <div class="notification-tips">
                                <h4><i class="fas fa-lightbulb"></i> Conseils</h4>
                                <ul>
                                    {% for conseil in notification.conseils %}
                                        <li>{{ conseil }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <!-- Schedule Section -->
            <div class="schedule-section">
                <div class="section-header">
                    <h2 class="section-subtitle">
                        <i class="fas fa-calendar-week"></i> Emploi du Temps
                    </h2>
                </div>

                <!-- Filter Form -->
                <div class="filter-card">
                    <form method="GET" action="{{ path('app_stresse_agenda') }}">
                        <div class="filter-grid">
                            <div class="filter-group">
                                <label for="matiere_par_jour">
                                    <i class="fas fa-book"></i> Matières/jour
                                </label>
                                <input type="number" id="matiere_par_jour" name="matiere_par_jour" 
                                       class="filter-input" min="1" max="8" 
                                       value="{{ parametres.matiereParJour }}">
                            </div>
                            
                            <div class="filter-group">
                                <label for="heure_debut">
                                    <i class="fas fa-sun"></i> Début
                                </label>
                                <input type="number" id="heure_debut" name="heure_debut" 
                                       class="filter-input" min="6" max="22" 
                                       value="{{ parametres.heureDebut }}">
                            </div>
                            
                            <div class="filter-group">
                                <label for="periode">
                                    <i class="fas fa-calendar-week"></i> Période
                                </label>
                                <select id="periode" name="periode" class="filter-select">
                                    <option value="semaine" {% if parametres.periode == 'semaine' %}selected{% endif %}>Semaine</option>
                                    <option value="quinzaine" {% if parametres.periode == 'quinzaine' %}selected{% endif %}>Quinzaine</option>
                                    <option value="mois" {% if parametres.periode == 'mois' %}selected{% endif %}>Mois</option>
                                </select>
                            </div>
                            
                            <div class="filter-group">
                                <label for="niveau_stress">
                                    <i class="fas fa-heartbeat"></i> Stress
                                </label>
                                <input type="range" id="niveau_stress" name="niveau_stress" 
                                       class="filter-range" min="1" max="10" 
                                       value="{{ parametres.niveauStress }}">
                                <span class="range-value">{{ parametres.niveauStress }}/10</span>
                            </div>
                        </div>
                        
                        <div class="filter-actions">
                            <button type="submit" class="btn-filter">
                                <i class="fas fa-sync-alt"></i> Actualiser
                            </button>
                            <a href="{{ path('app_stresse_emploie_avance') }}" class="btn-filter btn-secondary">
                                <i class="fas fa-cog"></i> Avancé
                            </a>
                        </div>
                    </form>
                </div>

                <!-- Schedule Display -->
                <div class="schedule-grid">
                    {% set joursSemaine = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi'] %}
                    {% if parametres.inclureWeekend %}
                        {% set joursSemaine = joursSemaine|merge(['Samedi', 'Dimanche']) %}
                    {% endif %}
                    
                    {% for jour in joursSemaine %}
                        <div class="day-column {% if jour == "now"|date('l')|replace({'Monday': 'Lundi', 'Tuesday': 'Mardi', 'Wednesday': 'Mercredi', 'Thursday': 'Jeudi', 'Friday': 'Vendredi', 'Saturday': 'Samedi', 'Sunday': 'Dimanche'}) %}today{% endif %}">
                            <div class="day-header">{{ jour }}</div>
                            <div class="day-courses">
                                {% if emploiTemps[jour] is defined %}
                                    {% for cours in emploiTemps[jour] %}
                                        <div class="course-card">
                                            <div class="course-time">
                                                <i class="far fa-clock"></i>
                                                {{ cours.heureDebut }} - {{ cours.heureFin }}
                                            </div>
                                            <div class="course-info">
                                                <span class="course-name">{{ cours.matiere }}</span>
                                                <span class="efficiency-badge efficiency-{{ cours.efficacite|lower }}">
                                                    {{ cours.efficacite }}
                                                </span>
                                            </div>
                                        </div>
                                    {% endfor %}
                                {% else %}
                                    <div class="no-courses">
                                        <i class="fas fa-coffee"></i>
                                        <span>Pas de cours</span>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Upcoming Courses -->
            <div class="upcoming-section">
                <div class="section-header">
                    <h2 class="section-subtitle">
                        <i class="fas fa-forward"></i> Cours à Venir
                    </h2>
                </div>

                <div class="upcoming-grid">
                    {% for cours in coursAVoir %}
                        <div class="upcoming-card {% if cours.estAujourdhui %}today{% endif %}">
                            <div class="upcoming-date">
                                {% if cours.estAujourdhui %}
                                    <span class="date-badge">Aujourd'hui</span>
                                {% else %}
                                    <span class="date-badge">{{ cours.jour }}</span>
                                {% endif %}
                            </div>
                            <div class="upcoming-content">
                                <h4 class="upcoming-title">{{ cours.matiere }}</h4>
                                <p class="upcoming-time">
                                    <i class="far fa-clock"></i>
                                    {{ cours.heureDebut }} - {{ cours.heureFin }}
                                </p>
                            </div>
                            <span class="efficiency-badge efficiency-{{ cours.efficacite|lower }}">
                                {{ cours.efficacite }}
                            </span>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a href="{{ path('app_stresse_emploie_avance', {
                    'matiere_par_jour': parametres.matiereParJour,
                    'heure_par_matiere': parametres.heureParMatiere,
                    'pause': parametres.pause,
                    'heure_debut': parametres.heureDebut,
                    'periode': parametres.periode,
                    'inclure_weekend': parametres.inclureWeekend ? 1 : 0,
                    'niveau_stress': parametres.niveauStress,
                    'matieres': matieres|join(',')
                }) }}" class="btn-action btn-primary">
                    <i class="fas fa-sliders-h"></i>
                    <span>Modifier les paramètres</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
                <a href="{{ path('app_stresse_coach') }}" class="btn-action btn-secondary">
                    <i class="fas fa-user-tie"></i>
                    <span>Conseils anti-stress</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <!-- Contact Section -->
            <div class="contact-section">
                <h3><i class="fas fa-hand-holding-heart"></i> Besoin d'aide pour gérer votre stress ?</h3>
                <p>Consultez notre coach stress pour des conseils personnalisés</p>
                <a href="{{ path('app_stresse_coach') }}" class="btn-contact">
                    <i class="fas fa-spa"></i> Voir le coach stress
                </a>
            </div>
        </div>
    </div>

    <!-- Styles -->
    {% block stylesheets %}
        {{ parent() }}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <style>
            /* Reset & Base */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                min-height: 100vh;
            }

            /* Header */
            .header-area {
                background: rgba(0, 0, 0, 0.3) !important;
                backdrop-filter: blur(10px);
            }

            .header-area .logo h1,
            .header-area .nav a,
            .header-area .menu-trigger span,
            nav, .navbar, nav *, .navbar *, .nav-link {
                color: white !important;
            }

            /* Layout */
            .agenda-section {
                padding: 120px 20px 60px 20px;
                background-color: transparent;
                min-height: 100vh;
            }

            .container {
                max-width: 1400px;
                margin: 0 auto;
            }

            /* Typography */
            .section-title {
                font-size: 3rem;
                font-weight: 700;
                color: #ffffff;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
                margin: 0;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .section-subtitle {
                font-size: 2rem;
                font-weight: 700;
                color: #ffffff;
                text-align: center;
                margin-bottom: 30px;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            .description-text {
                font-size: 1.2rem;
                color: rgba(255, 255, 255, 0.9);
                max-width: 800px;
                margin: 0 auto;
                line-height: 1.6;
                text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
                text-align: center;
            }

            /* Header */
            .header-with-button {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 30px;
                flex-wrap: wrap;
                gap: 20px;
            }

            .header-icon .emoji {
                font-size: 4rem;
                filter: drop-shadow(2px 2px 4px rgba(0, 0, 0, 0.2));
            }

            /* Quick Stats */
            .quick-stats {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                gap: 20px;
                margin-bottom: 40px;
            }

            .stat-card {
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(10px);
                border-radius: 20px;
                padding: 25px;
                display: flex;
                align-items: center;
                gap: 20px;
                transition: all 0.3s ease;
                border: 2px solid rgba(255, 255, 255, 0.1);
            }

            .stat-card:hover {
                transform: translateY(-5px);
                background: rgba(255, 255, 255, 0.2);
            }

            .stat-icon {
                width: 60px;
                height: 60px;
                background: rgba(255, 255, 255, 0.2);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.8rem;
                color: white;
            }

            .stat-content {
                display: flex;
                flex-direction: column;
            }

            .stat-value {
                font-size: 2rem;
                font-weight: 700;
                color: white;
                line-height: 1.2;
            }

            .stat-label {
                font-size: 0.9rem;
                color: rgba(255, 255, 255, 0.8);
            }

            /* Daily Tip Card */
            .daily-tip-card {
                background: linear-gradient(135deg, #FF6B6B 0%, #C92A2A 100%);
                color: white;
                padding: 25px 35px;
                border-radius: 20px;
                margin-bottom: 40px;
                box-shadow: 0 10px 30px rgba(255, 107, 107, 0.3);
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .tip-label {
                font-weight: 600;
                font-size: 1rem;
                text-transform: uppercase;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .tip-label i {
                font-size: 1.2rem;
            }

            .tip-text {
                font-size: 1.2rem;
                margin: 0;
                line-height: 1.5;
            }

            /* Notifications */
            .notifications-section {
                margin-bottom: 50px;
            }

            .notifications-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
                gap: 25px;
            }

            .notification-card {
                background: white;
                border-radius: 20px;
                padding: 25px;
                transition: all 0.3s ease;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
                position: relative;
                overflow: hidden;
            }

            .notification-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            }

            .notification-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 4px;
                height: 100%;
            }

            .notification-en_cours::before { background: #ff4757; }
            .notification-imminent::before { background: #ffa502; }
            .notification-proche::before { background: #ffa502; }
            .notification-avenir::before { background: #2ed573; }

            .notification-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 15px;
            }

            .notification-icon {
                width: 45px;
                height: 45px;
                background: #f0f4ff;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #667eea;
                font-size: 1.3rem;
            }

            .notification-badge {
                padding: 5px 15px;
                border-radius: 30px;
                font-size: 0.75rem;
                font-weight: 600;
                text-transform: uppercase;
            }

            .badge-haute { background: #ff4757; color: white; }
            .badge-moyenne { background: #ffa502; color: white; }
            .badge-basse { background: #2ed573; color: white; }

            .notification-body {
                margin-bottom: 15px;
            }

            .notification-title {
                font-size: 1.2rem;
                font-weight: 700;
                color: #1a1a1a;
                margin-bottom: 5px;
            }

            .notification-message {
                color: #666;
                font-size: 0.95rem;
                margin-bottom: 10px;
                line-height: 1.5;
            }

            .notification-meta {
                display: flex;
                gap: 15px;
                color: #888;
                font-size: 0.85rem;
            }

            .notification-meta i {
                margin-right: 5px;
            }

            .notification-tips {
                background: #f8f9ff;
                padding: 15px;
                border-radius: 12px;
                margin-top: 15px;
            }

            .notification-tips h4 {
                color: #667eea;
                font-size: 0.95rem;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .notification-tips ul {
                padding-left: 20px;
                margin: 0;
            }

            .notification-tips li {
                color: #555;
                font-size: 0.9rem;
                margin-bottom: 5px;
            }

            /* Filter Card */
            .filter-card {
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(10px);
                border-radius: 20px;
                padding: 30px;
                margin-bottom: 40px;
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .filter-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                gap: 25px;
                margin-bottom: 25px;
            }

            .filter-group {
                display: flex;
                flex-direction: column;
            }

            .filter-group label {
                color: white;
                font-size: 0.9rem;
                margin-bottom: 8px;
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .filter-input,
            .filter-select {
                padding: 12px 15px;
                border: none;
                border-radius: 12px;
                background: rgba(255, 255, 255, 0.9);
                font-size: 1rem;
                transition: all 0.3s ease;
            }

            .filter-input:focus,
            .filter-select:focus {
                outline: none;
                background: white;
                box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
            }

            .filter-range {
                width: 100%;
                margin: 5px 0;
            }

            .range-value {
                color: white;
                font-size: 0.9rem;
                text-align: right;
            }

            .filter-actions {
                display: flex;
                gap: 15px;
                justify-content: flex-end;
                flex-wrap: wrap;
            }

            .btn-filter {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 12px 25px;
                background: #2ed573;
                color: white;
                border: none;
                border-radius: 30px;
                font-weight: 600;
                font-size: 0.95rem;
                cursor: pointer;
                transition: all 0.3s ease;
                text-decoration: none;
            }

            .btn-filter:hover {
                background: #26af61;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(46, 213, 115, 0.3);
                color: white;
            }

            .btn-filter.btn-secondary {
                background: rgba(255, 255, 255, 0.2);
                backdrop-filter: blur(5px);
            }

            .btn-filter.btn-secondary:hover {
                background: rgba(255, 255, 255, 0.3);
            }

            /* Schedule Grid */
            .schedule-grid {
                display: grid;
                grid-template-columns: repeat(5, 1fr);
                gap: 15px;
                margin-bottom: 40px;
            }

            @media (max-width: 1200px) {
                .schedule-grid { grid-template-columns: repeat(3, 1fr); }
            }
            @media (max-width: 768px) {
                .schedule-grid { grid-template-columns: repeat(2, 1fr); }
            }
            @media (max-width: 480px) {
                .schedule-grid { grid-template-columns: 1fr; }
            }

            .day-column {
                background: rgba(255, 255, 255, 0.95);
                border-radius: 20px;
                overflow: hidden;
                transition: all 0.3s ease;
            }

            .day-column.today {
                box-shadow: 0 0 0 3px #2ed573, 0 10px 30px rgba(0, 0, 0, 0.3);
            }

            .day-header {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
                padding: 15px;
                font-weight: 700;
                text-align: center;
                font-size: 1rem;
            }

            .day-column.today .day-header {
                background: linear-gradient(135deg, #2ed573 0%, #26af61 100%);
            }

            .day-courses {
                padding: 15px;
                min-height: 250px;
            }

            .course-card {
                background: #f8f9fa;
                border-radius: 12px;
                padding: 12px;
                margin-bottom: 10px;
                transition: all 0.3s ease;
                border-left: 3px solid #667eea;
            }

            .course-card:hover {
                transform: translateX(3px);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            }

            .course-time {
                color: #667eea;
                font-size: 0.8rem;
                font-weight: 600;
                margin-bottom: 5px;
            }

            .course-time i {
                margin-right: 3px;
            }

            .course-info {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .course-name {
                font-weight: 600;
                color: #333;
                font-size: 0.9rem;
            }

            .efficiency-badge {
                padding: 3px 10px;
                border-radius: 20px;
                font-size: 0.7rem;
                font-weight: 600;
            }

            .efficiency-haute { background: #ff4757; color: white; }
            .efficiency-normale { background: #ffa502; color: white; }
            .efficiency-basse { background: #2ed573; color: white; }

            .no-courses {
                text-align: center;
                padding: 30px 10px;
                color: #999;
            }

            .no-courses i {
                font-size: 2rem;
                margin-bottom: 10px;
                display: block;
            }

            /* Upcoming Courses */
            .upcoming-section {
                margin-bottom: 50px;
            }

            .upcoming-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 15px;
            }

            .upcoming-card {
                background: white;
                border-radius: 15px;
                padding: 20px;
                display: flex;
                align-items: center;
                gap: 15px;
                transition: all 0.3s ease;
                box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
            }

            .upcoming-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            }

            .upcoming-card.today {
                border-left: 4px solid #2ed573;
            }

            .upcoming-date {
                min-width: 100px;
            }

