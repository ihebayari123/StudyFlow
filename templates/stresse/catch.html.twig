                .nav-tabs .nav-link {
                    justify-content: center;
                }

                .techniques-grid,
                .workshops-grid {
                    grid-template-columns: 1fr;
                }

                .technique-image,
                .workshop-image {
                    height: 160px;
                }

                .logo-container {
