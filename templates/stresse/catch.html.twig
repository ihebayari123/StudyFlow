{% extends 'base.html.twig' %}

{% block title %}Coach Stress - Gestion du Stress Scolaire{% endblock %}

{% block body %}
    <!-- Header -->
    {% block header %}
        {% include 'home/navbar.html.twig' %}
    {% endblock %}

    <!-- Main Content -->
    <div class="coach-section">
        <div class="container">
            <!-- Page Header -->
            <div class="header-with-button">
                <h1 class="section-title">🧘 Coach Stress</h1>
                <div class="header-icon">
                    <span class="emoji">🌿</span>
                </div>
            </div>

            <!-- Page Description -->
            <div class="description-section">
                <p class="description-text">
                    Votre assistant personnel pour gérer la pression scolaire et retrouver votre équilibre.
                </p>
            </div>

            <!-- Quick Tip of the Day -->
            <div class="daily-tip-card">
                <div class="tip-label">
                    <i class="fas fa-lightbulb"></i> Conseil du jour
                </div>
                <p class="tip-text">{{ dailyTips[0] }}</p>
            </div>

            <!-- Navigation Tabs -->
            <div class="tabs-container">
                <ul class="nav nav-tabs" id="coachTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="breathing-tab" data-bs-toggle="tab" data-bs-target="#breathing" type="button" role="tab">
                            <i class="fas fa-lungs"></i> Respiration
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="relaxation-tab" data-bs-toggle="tab" data-bs-target="#relaxation" type="button" role="tab">
                            <i class="fas fa-spa"></i> Relaxation
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="time-tab" data-bs-toggle="tab" data-bs-target="#time" type="button" role="tab">
                            <i class="fas fa-clock"></i> Organisation
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="workshops-tab" data-bs-toggle="tab" data-bs-target="#workshops" type="button" role="tab">
                            <i class="fas fa-users"></i> Ateliers
                        </button>
                    </li>
                </ul>
            </div>

            <!-- Tab Content -->
            <div class="tab-content" id="coachTabContent">
                <!-- Breathing Techniques -->
                <div class="tab-pane fade show active" id="breathing" role="tabpanel">
                    <div class="section-header">
                        <h2 class="section-subtitle">
                            <i class="fas fa-lungs"></i> Techniques de Respiration
                        </h2>
                        <p class="section-description">Des exercices simples pour calmer votre esprit</p>
                    </div>
                    
                    <div class="techniques-grid">
                        {% for technique in breathingTechniques %}
                        <div class="technique-card">
                            <div class="technique-image">
                                <div class="technique-logo">
                                    <div class="logo-container logo-primary">
                                        {% if technique.icon == 'lungs' %}
                                            <i class="fas fa-lungs"></i>
                                        {% elseif technique.icon == 'clock' %}
                                            <i class="fas fa-hourglass-half"></i>
                                        {% else %}
                                            <i class="fas fa-circle"></i>
                                        {% endif %}
                                    </div>
                                </div>
                                <span class="technique-category">Respiration</span>
                            </div>
                            <div class="technique-content">
                                <h3 class="technique-title">{{ technique.name }}</h3>
                                <p class="technique-description">{{ technique.description }}</p>
                                <div class="technique-meta">
                                    <span class="duration-badge">
                                        <i class="far fa-clock"></i> {{ technique.duration }}
                                    </span>
                                </div>
                                <div class="technique-steps">
                                    <h4><i class="fas fa-list-ol"></i> Étapes :</h4>
                                    <ol>
                                        {% for step in technique.steps %}
                                        <li>{{ step }}</li>
                                        {% endfor %}
                                    </ol>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Relaxation Techniques -->
                <div class="tab-pane fade" id="relaxation" role="tabpanel">
                    <div class="section-header">
                        <h2 class="section-subtitle">
                            <i class="fas fa-spa"></i> Techniques de Relaxation
                        </h2>
                        <p class="section-description">Détendez votre corps et votre esprit</p>
                    </div>
                    
                    <div class="techniques-grid">
                        {% for technique in relaxationTechniques %}
                        <div class="technique-card">
                            <div class="technique-image">
                                <div class="technique-logo">
                                    <div class="logo-container logo-secondary">
                                        {% if technique.icon == 'spa' %}
                                            <i class="fas fa-spa"></i>
                                        {% elseif technique.icon == 'sun' %}
                                            <i class="fas fa-sun"></i>
                                        {% else %}
                                            <i class="fas fa-leaf"></i>
                                        {% endif %}
                                    </div>
                                </div>
                                <span class="technique-category">Relaxation</span>
                            </div>
                            <div class="technique-content">
                                <h3 class="technique-title">{{ technique.name }}</h3>
                                <p class="technique-description">{{ technique.description }}</p>
                                <div class="technique-meta">
                                    <span class="duration-badge">
                                        <i class="far fa-clock"></i> {{ technique.duration }}
                                    </span>
                                </div>
                                <div class="technique-steps">
                                    <h4><i class="fas fa-list-ol"></i> Étapes :</h4>
                                    <ol>
                                        {% for step in technique.steps %}
                                        <li>{{ step }}</li>
                                        {% endfor %}
                                    </ol>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Time Organization -->
                <div class="tab-pane fade" id="time" role="tabpanel">
                    <div class="section-header">
                        <h2 class="section-subtitle">
                            <i class="fas fa-clock"></i> Organisation du Temps
                        </h2>
                        <p class="section-description">Gérez efficacement vos études et votre repos</p>
                    </div>
                    
                    <div class="techniques-grid">
                        {% for technique in timeOrganization %}
                        <div class="technique-card">
                            <div class="technique-image">
                                <div class="technique-logo">
                                    <div class="logo-container logo-tertiary">
                                        {% if technique.icon == 'tomato' %}
                                            <i class="fas fa-clock"></i>
                                        {% elseif technique.icon == 'matrix' %}
                                            <i class="fas fa-th"></i>
                                        {% else %}
                                            <i class="fas fa-calendar-alt"></i>
                                        {% endif %}
                                    </div>
                                </div>
                                <span class="technique-category">Organisation</span>
                            </div>
                            <div class="technique-content">
                                <h3 class="technique-title">{{ technique.name }}</h3>
                                <p class="technique-description">{{ technique.description }}</p>
                                <div class="technique-steps">
                                    <h4><i class="fas fa-list-ol"></i> Étapes :</h4>
                                    <ol>
                                        {% for step in technique.steps %}
                                        <li>{{ step }}</li>
                                        {% endfor %}
                                    </ol>
                                </div>
                                {% if technique.tips %}
                                <div class="technique-tips">
                                    <h4><i class="fas fa-lightbulb"></i> Conseils :</h4>
                                    <ul>
                                        {% for tip in technique.tips %}
                                        <li>{{ tip }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                {% endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Workshops -->
                <div class="tab-pane fade" id="workshops" role="tabpanel">
                    <div class="section-header">
                        <h2 class="section-subtitle">
                            <i class="fas fa-users"></i> Ateliers de Gestion du Stress
                        </h2>
                        <p class="section-description">Participez à nos ateliers interactifs</p>
                    </div>
                    
                    <div class="workshops-grid">
                        <!-- Atelier Gestion du Temps -->
                        <div class="workshop-card">
                            <div class="workshop-image">
                                <div class="workshop-logo">
                                    <div class="logo-container" style="background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);">
                                        <i class="fas fa-clock"></i>
                                    </div>
                                </div>
                                <div class="workshop-level">
                                    <span class="level-badge intermédiaire">Intermédiaire</span>
                                </div>
                            </div>
                            <div class="workshop-content">
                                <h3 class="workshop-title">Gestion du Temps</h3>
                                <p class="workshop-description">
                                    Apprenez à organiser votre emploi du temps pour réduire le stress lié aux échéances.
                                </p>
                                <div class="workshop-meta">
                                    <span class="duration-badge">
                                        <i class="far fa-clock"></i> 2 heures
                                    </span>
                                </div>
                                <div class="workshop-topics">
                                    <h4><i class="fas fa-tags"></i> Au programme :</h4>
                                    <ul>
                                        <li>Priorisation des tâches</li>
                                        <li>Technique Pomodoro</li>
                                        <li>Planification efficace</li>
                                        <li>Éviter la procrastination</li>
                                    </ul>
                                </div>
                                <a href="{{ path('app_stresse_gestion_temps') }}" class="workshop-btn btn-organization">
                                    <i class="fas fa-clock"></i>
                                    <span>Gestion du Temps</span>
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Atelier Préparation Examens -->
                        <div class="workshop-card">
                            <div class="workshop-image">
                                <div class="workshop-logo">
                                    <div class="logo-container" style="background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);">
                                        <i class="fas fa-graduation-cap"></i>
                                    </div>
                                </div>
                                <div class="workshop-level">
                                    <span class="level-badge tous">Tous niveaux</span>
                                </div>
                            </div>
                            <div class="workshop-content">
                                <h3 class="workshop-title">Préparation aux Examens</h3>
                                <p class="workshop-description">
                                    Techniques de révision et stratégies pour aborder sereinement vos examens.
                                </p>
                                <div class="workshop-meta">
                                    <span class="duration-badge">
                                        <i class="far fa-clock"></i> 3 heures
                                    </span>
                                </div>
                                <div class="workshop-topics">
                                    <h4><i class="fas fa-tags"></i> Au programme :</h4>
                                    <ul>
                                        <li>Méthodes de révision efficaces</li>
                                        <li>Gestion du stress avant l'examen</li>
                                        <li>Techniques de mémorisation</li>
                                        <li>Stratégies le jour J</li>
                                    </ul>
                                </div>
                                <a href="{{ path('app_stresse_preparation_examens') }}" class="workshop-btn btn-preparation">
                                    <i class="fas fa-graduation-cap"></i>
                                    <span>Préparation Examens</span>
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Additional Tips Section -->
            <div class="additional-tips">
                <h2 class="section-subtitle">
                    <i class="fas fa-lightbulb"></i> Autres Conseils Utiles
                </h2>
                <div class="tips-grid">
                    {% for tip in dailyTips %}
                    <div class="tip-card">
                        <div class="tip-icon">
                            <span class="tip-number">{{ loop.index }}</span>
                        </div>
                        <p class="tip-text">{{ tip }}</p>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Contact Section -->
            <div class="contact-section">
                <h3><i class="fas fa-hand-holding-heart"></i> Besoin d'aide supplémentaire ?</h3>
                <p>N'hésitez pas à contacter un professionnel de santé si le stress devient trop intense.</p>
                <a href="{{ path('app_stresse') }}" class="btn-contact">
                    <i class="fas fa-chart-line"></i> Évaluer mon niveau de stress
                </a>
            </div>
        </div>
    </div>

    <!-- Styles -->
    {% block stylesheets %}
        {{ parent() }}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <style>
            /* Reset & Base */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                min-height: 100vh;
            }

            /* Header */
            .header-area {
                background: rgba(0, 0, 0, 0.3) !important;
                backdrop-filter: blur(10px);
            }

            .header-area .logo h1,
            .header-area .nav a,
            .header-area .menu-trigger span,
            nav, .navbar, nav *, .navbar *, .nav-link {
                color: white !important;
            }

            /* Layout */
            .coach-section {
                padding: 120px 20px 60px 20px;
                background-color: transparent;
                min-height: 100vh;
            }

            .container {
                max-width: 1400px;
                margin: 0 auto;
            }

            /* Typography */
            .section-title {
                font-size: 3rem;
                font-weight: 700;
                color: #ffffff;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
                margin: 0;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .section-subtitle {
                font-size: 2rem;
                font-weight: 700;
                color: #ffffff;
                text-align: center;
                margin-bottom: 20px;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            .section-description {
                font-size: 1.2rem;
                color: rgba(255, 255, 255, 0.9);
                text-align: center;
                margin-bottom: 40px;
            }

            .description-text {
                font-size: 1.2rem;
                color: rgba(255, 255, 255, 0.9);
                max-width: 800px;
                margin: 0 auto;
                line-height: 1.6;
                text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
            }

            /* Header */
            .header-with-button {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 30px;
                flex-wrap: wrap;
                gap: 20px;
            }

            .header-icon .emoji {
                font-size: 4rem;
                filter: drop-shadow(2px 2px 4px rgba(0, 0, 0, 0.2));
            }

            /* Description Section */
            .description-section {
                margin-bottom: 40px;
                text-align: center;
            }

            /* Daily Tip Card */
            .daily-tip-card {
                background: linear-gradient(135deg, #FF6B6B 0%, #C92A2A 100%);
                color: white;
                padding: 25px 35px;
                border-radius: 20px;
                margin-bottom: 40px;
                box-shadow: 0 10px 30px rgba(255, 107, 107, 0.3);
                border: 2px solid rgba(255, 255, 255, 0.2);
                backdrop-filter: blur(10px);
            }

            .tip-label {
                font-weight: 600;
                font-size: 1rem;
                text-transform: uppercase;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .tip-label i {
                font-size: 1.2rem;
            }

            .tip-text {
                font-size: 1.3rem;
                margin: 0;
                line-height: 1.5;
            }

            /* Tabs */
            .tabs-container {
                margin-bottom: 40px;
            }

            .nav-tabs {
                border: none;
                display: flex;
                gap: 10px;
                flex-wrap: wrap;
                justify-content: center;
            }

            .nav-tabs .nav-link {
                border: none;
                padding: 15px 30px;
                border-radius: 30px;
                background: rgba(255, 255, 255, 0.15);
                color: white;
                font-weight: 600;
                transition: all 0.3s ease;
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.1);
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .nav-tabs .nav-link:hover {
                background: rgba(255, 255, 255, 0.25);
                transform: translateY(-2px);
            }

            .nav-tabs .nav-link.active {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            /* Techniques Grid */
            .techniques-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
                gap: 30px;
                margin-bottom: 50px;
            }

            .technique-card {
                background: white;
                border-radius: 20px;
                overflow: hidden;
                transition: all 0.3s ease;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            }

            .technique-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            }

            .technique-image {
                position: relative;
                height: 180px;
                background: linear-gradient(135deg, #f0f4ff 0%, #e6e9ff 100%);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .technique-logo {
                text-align: center;
            }

            .logo-container {
                width: 90px;
                height: 90px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2.2rem;
                color: white;
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            }

            .logo-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
            .logo-secondary { background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%); }
            .logo-tertiary { background: linear-gradient(135deg, #FF9800 0%, #FF5722 100%); }
            .logo-quaternary { background: linear-gradient(135deg, #2196F3 0%, #0D47A1 100%); }

            .technique-category {
                position: absolute;
                top: 15px;
                left: 15px;
                background: white;
                color: #7b68ee;
                padding: 8px 20px;
                border-radius: 25px;
                font-weight: 600;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .technique-content {
                padding: 25px;
            }

            .technique-title {
                color: #1a1a1a;
                font-size: 1.5rem;
                font-weight: 700;
                margin-bottom: 10px;
            }

            .technique-description {
                color: #666;
                font-size: 0.95rem;
                line-height: 1.5;
                margin-bottom: 15px;
            }

            .technique-meta {
                margin-bottom: 15px;
            }

            .duration-badge {
                display: inline-flex;
                align-items: center;
                gap: 5px;
                background: #f0f4ff;
                color: #667eea;
                padding: 5px 12px;
                border-radius: 20px;
                font-size: 0.9rem;
                font-weight: 600;
            }

            .duration-badge i {
                font-size: 0.9rem;
            }

            .technique-steps h4,
            .technique-tips h4 {
                color: #333;
                font-size: 1rem;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .technique-steps ol,
            .technique-tips ul {
                padding-left: 25px;
                margin-bottom: 0;
            }

            .technique-steps li,
            .technique-tips li {
                color: #555;
                margin-bottom: 5px;
                line-height: 1.5;
            }

            .technique-tips {
                margin-top: 15px;
                padding-top: 15px;
                border-top: 1px solid #eee;
            }

            .technique-tips li {
                color: #4CAF50;
            }

            /* Workshops Grid */
            .workshops-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
                gap: 30px;
                margin-bottom: 50px;
            }

            .workshop-card {
                background: white;
                border-radius: 20px;
                overflow: hidden;
                transition: all 0.3s ease;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
                display: flex;
                flex-direction: column;
            }

            .workshop-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            }

            .workshop-image {
                position: relative;
                height: 180px;
                background: linear-gradient(135deg, #f0f4ff 0%, #e6e9ff 100%);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .workshop-logo {
                text-align: center;
            }

            .workshop-level {
                position: absolute;
                top: 15px;
                right: 15px;
            }

            .level-badge {
                padding: 8px 15px;
                border-radius: 25px;
                font-size: 0.8rem;
                font-weight: 600;
                background: white;
            }

            .level-badge.débutant {
                color: #2e7d32;
            }

            .level-badge.intermédiaire {
                color: #ef6c00;
            }

            .level-badge.tous {
                color: #1565c0;
            }

            .workshop-content {
                padding: 25px;
                flex: 1;
                display: flex;
                flex-direction: column;
            }

            .workshop-title {
                color: #1a1a1a;
                font-size: 1.4rem;
                font-weight: 700;
                margin-bottom: 10px;
            }

            .workshop-description {
                color: #666;
                font-size: 0.95rem;
                line-height: 1.5;
                margin-bottom: 15px;
            }

            .workshop-meta {
                margin-bottom: 15px;
            }

            .workshop-topics {
                margin-bottom: 20px;
            }

            .workshop-topics h4 {
                color: #333;
                font-size: 1rem;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .workshop-topics ul {
                padding-left: 25px;
            }

            .workshop-topics li {
                color: #555;
                margin-bottom: 3px;
            }

            /* Styles des boutons d'atelier */
            .workshop-btn {
                display: inline-flex;
                align-items: center;
                justify-content: space-between;
                width: 100%;
                padding: 14px 20px;
                margin-top: auto;
                border: none;
                border-radius: 50px;
                font-weight: 600;
                font-size: 1rem;
                cursor: pointer;
                transition: all 0.3s ease;
                text-decoration: none;
                color: white;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
                position: relative;
                overflow: hidden;
            }

            .workshop-btn i:first-child {
                font-size: 1.2rem;
            }

            .workshop-btn i:last-child {
                opacity: 0;
                transform: translateX(-10px);
                transition: all 0.3s ease;
            }

            .workshop-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
                text-decoration: none;
                color: white;
            }

            .workshop-btn:hover i:last-child {
                opacity: 1;
                transform: translateX(0);
            }

            .workshop-btn:active {
                transform: translateY(0);
            }

            /* Bouton Organisation/Gestion du temps */
            .btn-organization {
                background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
            }

            .btn-organization:hover {
                background: linear-gradient(135deg, #F57C00 0%, #EF6C00 100%);
            }

            /* Bouton Préparation Examens */
            .btn-preparation {
                background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
            }

            .btn-preparation:hover {
                background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
            }

            /* Animation d'onde pour les boutons */
            .workshop-btn::after {
                content: '';
                position: absolute;
                top: 50%;
                left: 50%;
                width: 300px;
                height: 300px;
                background: rgba(255, 255, 255, 0.2);
                border-radius: 50%;
                transform: translate(-50%, -50%) scale(0);
                opacity: 0;
                transition: transform 0.5s, opacity 0.3s;
            }

            .workshop-btn:active::after {
                transform: translate(-50%, -50%) scale(1);
                opacity: 1;
                transition: 0s;
            }

            /* Additional Tips */
            .additional-tips {
                margin: 50px 0;
                padding: 40px;
                background: rgba(255, 255, 255, 0.1);
                border-radius: 20px;
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .tips-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
                gap: 20px;
                margin-top: 30px;
            }

            .tip-card {
                background: rgba(255, 255, 255, 0.15);
                border-radius: 15px;
                padding: 20px;
                display: flex;
                align-items: flex-start;
                gap: 15px;
                transition: all 0.3s ease;
                border: 2px solid rgba(255, 255, 255, 0.1);
            }

            .tip-card:hover {
                background: rgba(255, 255, 255, 0.25);
                transform: translateY(-5px);
            }

            .tip-icon {
                flex-shrink: 0;
            }

            .tip-number {
                width: 35px;
                height: 35px;
                background: rgba(255, 255, 255, 0.2);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: 700;
                font-size: 1.1rem;
            }

            .tip-card p {
                margin: 0;
                color: white;
                font-size: 0.95rem;
                line-height: 1.5;
            }

            /* Contact Section */
            .contact-section {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
                padding: 50px;
                border-radius: 20px;
                text-align: center;
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .contact-section h3 {
                font-size: 1.8rem;
                margin-bottom: 15px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            .contact-section p {
                font-size: 1.1rem;
                opacity: 0.9;
                margin-bottom: 25px;
                max-width: 600px;
                margin-left: auto;
                margin-right: auto;
            }

            .btn-contact {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                padding: 15px 35px;
                background: white;
                color: #667eea;
                text-decoration: none;
                border-radius: 30px;
                font-weight: 600;
                font-size: 1.1rem;
                transition: all 0.3s ease;
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }

            .btn-contact:hover {
                transform: scale(1.05);
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
                color: #667eea;
                text-decoration: none;
            }

            /* Responsive */
            @media (max-width: 768px) {
                .coach-section {
                    padding: 100px 15px 40px 15px;
                }

                .header-with-button {
                    flex-direction: column;
                    text-align: center;
                }

                .section-title {
                    font-size: 2.2rem;
                    justify-content: center;
                }

                .section-subtitle {
                    font-size: 1.6rem;
                }

                .description-text,
                .section-description {
                    font-size: 1rem;
                }

                .daily-tip-card {
                    padding: 20px;
