{% extends 'base.html.twig' %}

{% block title %}Préparation Mentale aux Examens - StudyFlow{% endblock %}

{% block body %}
    <!-- Header -->
    {% block header %}
        {% include 'home/navbar.html.twig' %}
    {% endblock %}

    <!-- Main Content -->
    <div class="exam-prep-section">
        <div class="container">
            <!-- Page Header -->
            <div class="header-with-button">
                <h1 class="section-title">📚 Préparation Mentale <span class="accent">aux Examens</span></h1>
                <div class="header-icon">
                    <span class="emoji">🎯</span>
                </div>
            </div>

            <!-- Page Description -->
            <div class="description-section">
                <p class="description-text">
                    Techniques et stratégies pour gérer votre stress et réussir vos examens en toute sérénité.
                </p>
            </div>

            <!-- Quick Stats -->
            <div class="stats-container">
                <div class="stat-card">
                    <span class="stat-icon">🧠</span>
                    <div class="stat-info">
                        <span class="stat-value">85%</span>
                        <span class="stat-label">mental</span>
                    </div>
                </div>
                <div class="stat-card">
                    <span class="stat-icon">💪</span>
                    <div class="stat-info">
                        <span class="stat-value">15%</span>
                        <span class="stat-label">contenu</span>
                    </div>
                </div>
                <div class="stat-card">
                    <span class="stat-icon">🎯</span>
                    <div class="stat-info">
                        <span class="stat-value">100%</span>
                        <span class="stat-label">confiance</span>
                    </div>
                </div>
            </div>

            <!-- Quick Tip of the Day -->
            <div class="daily-tip-card">
                <div class="tip-label">
                    <i class="fas fa-lightbulb"></i> Conseil du jour
                </div>
                <p class="tip-text">La préparation mentale est aussi importante que la révision du contenu. Prenez 5 minutes pour respirer avant chaque session d'étude.</p>
            </div>

            <!-- Navigation Tabs -->
            <div class="tabs-container">
                <ul class="nav nav-tabs" id="examTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="techniques-tab" data-bs-toggle="tab" data-bs-target="#techniques" type="button" role="tab">
                            <i class="fas fa-brain"></i> Techniques
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="pratique-tab" data-bs-toggle="tab" data-bs-target="#pratique" type="button" role="tab">
                            <i class="fas fa-tasks"></i> Pratique
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="stress-tab" data-bs-toggle="tab" data-bs-target="#stress" type="button" role="tab">
                            <i class="fas fa-bolt"></i> Stress
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="checklist-tab" data-bs-toggle="tab" data-bs-target="#checklist" type="button" role="tab">
                            <i class="fas fa-check-circle"></i> Checklist
                        </button>
                    </li>
                </ul>
            </div>

            <!-- Tab Content -->
            <div class="tab-content" id="examTabContent">
                <!-- Techniques Section -->
                <div class="tab-pane fade show active" id="techniques" role="tabpanel">
                    <div class="section-header">
                        <h2 class="section-subtitle">
                            <i class="fas fa-brain"></i> Techniques de Préparation Mentale
                        </h2>
                        <p class="section-description">Maîtrisez votre esprit pour optimiser vos performances</p>
                    </div>
                    
                    <div class="techniques-grid">
                        {% for technique in techniquesPreparation %}
                        <div class="technique-card">
                            <div class="technique-image">
                                <div class="technique-logo">
                                    <div class="logo-container logo-primary">
                                        <span class="card-icon">{{ technique.icone }}</span>
                                    </div>
                                </div>
                                <span class="technique-category">{{ technique.duree }}</span>
                            </div>
                            <div class="technique-content">
                                <h3 class="technique-title">{{ technique.nom }}</h3>
                                <p class="technique-description">{{ technique.description }}</p>
                                
                                <div class="technique-timing">
                                    <span class="timing-badge">
                                        <i class="fas fa-clock"></i> {{ technique.quand }}
                                    </span>
                                </div>

                                <div class="technique-steps">
                                    <h4><i class="fas fa-list-ol"></i> Étapes :</h4>
                                    <ol>
                                        {% for etape in technique.etapes %}
                                        <li>
                                            <strong>{{ etape.titre }}</strong> - {{ etape.description }}
                                        </li>
                                        {% endfor %}
                                    </ol>
                                </div>

                                {% if technique.exemples is defined %}
                                <div class="technique-examples">
                                    <h4><i class="fas fa-quote-right"></i> Affirmations :</h4>
                                    <ul>
                                        {% for exemple in technique.exemples %}
                                        <li>{{ exemple }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                {% endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Preparation Pratique Section -->
                <div class="tab-pane fade" id="pratique" role="tabpanel">
                    <div class="section-header">
                        <h2 class="section-subtitle">
                            <i class="fas fa-tasks"></i> Préparation Pratique
                        </h2>
                        <p class="section-description">Checklist jour par jour pour être prêt le jour J</p>
                    </div>
                    
                    <div class="pratique-timeline">
                        {% for phase in preparationPratique %}
                        <div class="timeline-phase">
                            <div class="phase-header">
                                <span class="phase-icon">
                                    {% if loop.index == 1 %}🌙
                                    {% elseif loop.index == 2 %}☀️
                                    {% elseif loop.index == 3 %}✍️
                                    {% else %}🎉
                                    {% endif %}
                                </span>
                                <h3>{{ phase.categorie }}</h3>
                            </div>
                            <ul class="phase-actions">
                                {% for action in phase.actions %}
                                <li><i class="fas fa-check-circle"></i> {{ action }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Stress Management Section -->
                <div class="tab-pane fade" id="stress" role="tabpanel">
                    <div class="section-header">
                        <h2 class="section-subtitle">
                            <i class="fas fa-bolt"></i> Gestion du Stress
                        </h2>
                        <p class="section-description">Que faire quand le stress pointe le bout du nez ?</p>
                    </div>
                    
                    <div class="stress-grid">
                        {% for info in signesStress %}
                        <div class="stress-card">
                            <div class="stress-icon">
                                <span class="emoji">⚠️</span>
                            </div>
                            <div class="stress-content">
                                <h4>{{ info.signe }}</h4>
                                <p class="solution">{{ info.solution }}</p>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Checklist Section -->
                <div class="tab-pane fade" id="checklist" role="tabpanel">
                    <div class="section-header">
                        <h2 class="section-subtitle">
                            <i class="fas fa-check-circle"></i> Checklist Examen
                        </h2>
                        <p class="section-description">Tout ce qu'il ne faut pas oublier</p>
                    </div>
                    
                    <div class="checklist-container">
                        {% for item in checklist.items %}
                        <label class="checklist-item">
                            <input type="checkbox" class="checkbox">
                            <span class="checkmark"></span>
                            <span class="item-text">{{ item.item }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Resources Section -->
            <div class="resources-section">
                <h2 class="section-subtitle">
                    <i class="fas fa-tools"></i> Ressources Complémentaires
                </h2>
                <div class="resources-grid">
                    {% for ressource in ressources %}
                    <div class="resource-card">
                        <span class="resource-icon">{{ ressource.icone }}</span>
                        <div class="resource-content">
                            <span class="resource-type">{{ ressource.type }}</span>
                            <h4>{{ ressource.nom }}</h4>
                            <p>{{ ressource.description }}</p>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <!-- CTA Section -->
            <div class="cta-section">
                <h3><i class="fas fa-rocket"></i> Prêt à réussir ?</h3>
                <p>Combinez préparation mentale et travail régulier pour des résultats optimaux</p>
                <div class="cta-buttons">
                    <a href="{{ path('app_stresse') }}" class="btn-primary">
                        <i class="fas fa-chart-line"></i> Évaluer mon stress
                    </a>
                    <a href="{{ path('app_stresse_gestion_temps') }}" class="btn-secondary">
                        <i class="fas fa-clock"></i> Gestion du temps
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Styles -->
    {% block stylesheets %}
        {{ parent() }}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <style>
            /* Reset & Base */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                min-height: 100vh;
            }

            /* Header */
            .header-area {
                background: rgba(0, 0, 0, 0.3) !important;
                backdrop-filter: blur(10px);
            }

            .header-area .logo h1,
            .header-area .nav a,
            .header-area .menu-trigger span,
            nav, .navbar, nav *, .navbar *, .nav-link {
                color: white !important;
            }

            /* Layout */
            .exam-prep-section {
                padding: 120px 20px 60px 20px;
                background-color: transparent;
                min-height: 100vh;
            }

            .container {
                max-width: 1400px;
                margin: 0 auto;
            }

            /* Typography */
            .section-title {
                font-size: 3rem;
                font-weight: 700;
                color: #ffffff;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
                margin: 0;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .section-title .accent {
                color: #fbbf24;
            }

            .section-subtitle {
                font-size: 2rem;
                font-weight: 700;
                color: #ffffff;
                text-align: center;
                margin-bottom: 20px;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            .section-description {
                font-size: 1.2rem;
                color: rgba(255, 255, 255, 0.9);
                text-align: center;
                margin-bottom: 40px;
            }

            .description-text {
                font-size: 1.2rem;
                color: rgba(255, 255, 255, 0.9);
                max-width: 800px;
                margin: 0 auto;
                line-height: 1.6;
                text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
            }

            /* Header */
            .header-with-button {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 30px;
                flex-wrap: wrap;
                gap: 20px;
            }

            .header-icon .emoji {
                font-size: 4rem;
                filter: drop-shadow(2px 2px 4px rgba(0, 0, 0, 0.2));
            }

            /* Description Section */
            .description-section {
                margin-bottom: 40px;
                text-align: center;
            }

            /* Stats */
            .stats-container {
                display: flex;
                justify-content: center;
                gap: 30px;
                margin-bottom: 40px;
                flex-wrap: wrap;
            }

            .stat-card {
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.2);
                border-radius: 20px;
                padding: 25px 35px;
                display: flex;
                align-items: center;
                gap: 20px;
                min-width: 200px;
            }

            .stat-icon {
                font-size: 2.5rem;
            }

            .stat-info {
                display: flex;
                flex-direction: column;
            }

            .stat-value {
                font-size: 2rem;
                font-weight: 800;
                color: white;
                line-height: 1;
            }

            .stat-label {
                color: rgba(255, 255, 255, 0.8);
                font-size: 0.9rem;
                text-transform: uppercase;
            }

            /* Daily Tip Card */
            .daily-tip-card {
                background: linear-gradient(135deg, #FF6B6B 0%, #C92A2A 100%);
                color: white;
                padding: 25px 35px;
                border-radius: 20px;
                margin-bottom: 40px;
                box-shadow: 0 10px 30px rgba(255, 107, 107, 0.3);
                border: 2px solid rgba(255, 255, 255, 0.2);
                backdrop-filter: blur(10px);
            }

            .tip-label {
                font-weight: 600;
                font-size: 1rem;
                text-transform: uppercase;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .tip-label i {
                font-size: 1.2rem;
            }

            .tip-text {
                font-size: 1.3rem;
                margin: 0;
                line-height: 1.5;
            }

            /* Tabs */
            .tabs-container {
                margin-bottom: 40px;
            }

            .nav-tabs {
                border: none;
                display: flex;
                gap: 10px;
                flex-wrap: wrap;
                justify-content: center;
            }

            .nav-tabs .nav-link {
                border: none;
                padding: 15px 30px;
                border-radius: 30px;
                background: rgba(255, 255, 255, 0.15);
                color: white;
                font-weight: 600;
                transition: all 0.3s ease;
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.1);
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .nav-tabs .nav-link:hover {
                background: rgba(255, 255, 255, 0.25);
                transform: translateY(-2px);
            }

            .nav-tabs .nav-link.active {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            /* Techniques Grid */
            .techniques-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
                gap: 30px;
                margin-bottom: 50px;
            }

            .technique-card {
                background: white;
                border-radius: 20px;
                overflow: hidden;
                transition: all 0.3s ease;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            }

            .technique-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            }

            .technique-image {
                position: relative;
                height: 180px;
                background: linear-gradient(135deg, #f0f4ff 0%, #e6e9ff 100%);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .technique-logo {
                text-align: center;
            }

            .logo-container {
                width: 90px;
                height: 90px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2.2rem;
                color: white;
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            }

            .logo-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }

            .technique-category {
                position: absolute;
                top: 15px;
                left: 15px;
                background: white;
                color: #7b68ee;
                padding: 8px 20px;
                border-radius: 25px;
                font-weight: 600;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .technique-content {
                padding: 25px;
            }

            .technique-title {
                color: #1a1a1a;
                font-size: 1.5rem;
                font-weight: 700;
                margin-bottom: 10px;
            }

            .technique-description {
                color: #666;
                font-size: 0.95rem;
                line-height: 1.5;
                margin-bottom: 15px;
            }

            .technique-timing {
                margin-bottom: 15px;
            }

            .timing-badge {
                display: inline-flex;
                align-items: center;
                gap: 5px;
                background: #f0f4ff;
                color: #667eea;
                padding: 8px 15px;
                border-radius: 20px;
                font-size: 0.9rem;
                font-weight: 600;
            }

            .technique-steps h4,
            .technique-examples h4 {
                color: #333;
                font-size: 1rem;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .technique-steps ol,
            .technique-examples ul {
                padding-left: 25px;
                margin-bottom: 0;
            }

            .technique-steps li,
            .technique-examples li {
                color: #555;
                margin-bottom: 8px;
                line-height: 1.5;
            }

            .technique-examples {
                margin-top: 15px;
                padding-top: 15px;
                border-top: 1px solid #eee;
            }

            .technique-examples li {
                color: #4CAF50;
            }

            /* Pratique Timeline */
            .pratique-timeline {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 20px;
                margin-bottom: 50px;
            }

            .timeline-phase {
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.2);
                border-radius: 20px;
                padding: 25px;
                position: relative;
                color: white;
            }

            .timeline-phase::after {
                content: '→';
                position: absolute;
                right: -15px;
                top: 50%;
                transform: translateY(-50%);
                font-size: 1.5rem;
                color: white;
                opacity: 0.5;
            }

            .timeline-phase:last-child::after {
                display: none;
            }

            .phase-header {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 20px;
            }

            .phase-icon {
                font-size: 1.5rem;
            }

            .phase-header h3 {
                font-size: 1.1rem;
                margin: 0;
                color: white;
            }

            .phase-actions {
                list-style: none;
                padding: 0;
            }

            .phase-actions li {
                padding: 10px 0;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                font-size: 0.9rem;
                color: rgba(255, 255, 255, 0.9);
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .phase-actions li i {
                color: #4CAF50;
                font-size: 0.9rem;
            }

            .phase-actions li:last-child {
                border-bottom: none;
            }

            /* Stress Grid */
            .stress-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 20px;
                margin-bottom: 50px;
            }

            .stress-card {
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.2);
                border-radius: 15px;
                padding: 20px;
                display: flex;
                gap: 15px;
                color: white;
            }

            .stress-icon .emoji {
                font-size: 1.8rem;
            }

            .stress-content h4 {
                margin: 0 0 8px;
                font-size: 1.1rem;
                color: white;
            }

            .solution {
                margin: 0;
                font-size: 0.9rem;
                color: rgba(255, 255, 255, 0.9);
                line-height: 1.5;
            }

            /* Checklist */
            .checklist-container {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 15px;
                margin-bottom: 50px;
            }

            .checklist-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 15px;
                background: rgba(255, 255, 255, 0.15);
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.2);
                border-radius: 10px;
                cursor: pointer;
                transition: all 0.3s;
                color: white;
            }

            .checklist-item:hover {
                background: rgba(255, 255, 255, 0.25);
                transform: translateY(-2px);
            }

            .checkbox {
                width: 20px;
                height: 20px;
                accent-color: #667eea;
            }

            .item-text {
                font-weight: 500;
            }

            /* Resources Section */
            .resources-section {
                margin: 50px 0;
                padding: 40px;
                background: rgba(255, 255, 255, 0.1);
                border-radius: 20px;
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .resources-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
                gap: 20px;
                margin-top: 30px;
            }

            .resource-card {
                background: rgba(255, 255, 255, 0.15);
                border-radius: 15px;
                padding: 25px;
                text-align: center;
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.1);
                transition: all 0.3s ease;
            }

            .resource-card:hover {
                transform: translateY(-5px);
                background: rgba(255, 255, 255, 0.25);
            }

            .resource-icon {
                font-size: 2.5rem;
                display: block;
                margin-bottom: 15px;
            }

            .resource-type {
                display: inline-block;
                background: rgba(255, 255, 255, 0.2);
                color: white;
                padding: 4px 10px;
                border-radius: 10px;
                font-size: 0.75rem;
                margin-bottom: 10px;
            }

            .resource-content h4 {
                color: white;
                margin: 0 0 8px;
                font-size: 1.2rem;
            }

            .resource-content p {
                font-size: 0.9rem;
                color: rgba(255, 255, 255, 0.9);
                margin: 0;
                line-height: 1.5;
            }

            /* CTA Section */
            .cta-section {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                color: white;
                padding: 50px;
                border-radius: 20px;
                text-align: center;
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .cta-section h3 {
                font-size: 2rem;
                margin-bottom: 15px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            .cta-section p {
                font-size: 1.1rem;
                opacity: 0.9;
                margin-bottom: 30px;
            }

            .cta-buttons {
                display: flex;
                justify-content: center;
                gap: 15px;
                flex-wrap: wrap;
            }

            .btn-primary,
            .btn-secondary {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 14px 30px;
                border-radius: 30px;
                text-decoration: none;
                font-weight: 600;
                transition: all 0.3s ease;
                font-size: 1rem;
            }

            .btn-primary {
                background: white;
                color: #667eea;
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }

            .btn-secondary {
                background: transparent;
                color: white;
                border: 2px solid white;
            }

            .btn-primary:hover,
