{% extends 'base.html.twig' %}

{% block title %}QR Code - Téléchargement PDF{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0 text-center">📱 Scan pour Télécharger</h2>
                </div>
                <div class="card-body text-center">
                    <p class="lead mb-4">
                        Cliquez sur le bouton ci-dessous pour générer un QR Code.<br>
                        <small class="text-muted">Scannez-le avec votre téléphone pour télécharger le PDF des contacts médicaux.</small>
                    </p>
                    
                    <form method="POST" action="{{ path('app_stresse_codabar') }}">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-qrcode"></i> Générer le QR Code
                        </button>
                    </form>

                    {% if showBarcode %}
                        <div class="mt-5">
                            <h4 class="mb-3">Scannez ce QR Code</h4>
                            <div class="qrcode-container p-4 bg-light rounded">
                                <div id="qrcode"></div>
                            </div>
                            <p class="mt-3 text-muted">
                                <i class="fas fa-info-circle"></i> 
                                Pointez votre caméra vers le QR Code pour télécharger automatiquement le PDF
                            </p>
                            <div class="alert alert-success mt-3">
                                <strong>📄 Contenu du PDF :</strong>
                                <ul class="list-unstyled mt-2 mb-0">
                                    <li>✅ Liste des psychiatres</li>
                                    <li>✅ Pharmacies de garde</li>
                                    <li>✅ Hôpitaux et cliniques</li>
                                    <li>✅ Numéros d'urgence</li>
                                </ul>
                            </div>
                            <a href="{{ qrCodeUrl }}" class="btn btn-outline-primary mt-3" target="_blank">
                                <i class="fas fa-download"></i> Télécharger directement
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

{% if showBarcode %}
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        new QRCode(document.getElementById("qrcode"), {
            text: "{{ qrCodeUrl|e('js') }}",
            width: 280,
            height: 280,
            colorDark : "#000000",
            colorLight : "#ffffff",
            correctLevel : QRCode.CorrectLevel.H
        });
    });
</script>
{% endif %}

<style>
    .qrcode-container {
        display: inline-block;
        border: 3px solid #667eea;
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(102, 126, 234, 0.3);
    }
    #qrcode img, #qrcode canvas {
        display: block;
        margin: 0 auto;
    }
    .card {
        border: none;
        border-radius: 15px;
    }
    .card-header {
        border-radius: 15px 15px 0 0 !important;
        padding: 25px;
    }
    .btn-lg {
        padding: 15px 40px;
        font-size: 18px;
        border-radius: 30px;
    }
</style>
{% endblock %}
