{% extends 'base.html.twig' %}

{% block title %}Agenda des Cours - StudyFlow{% endblock %}

{% block body %}
    <!-- Header -->
    {% block header %}
        {% include 'home/navbar.html.twig' %}
    {% endblock %}

    <!-- Main Content -->
    <div class="agenda-section">
        <div class="container">
            <!-- Page Header -->
            <div class="header-with-button">
                <h1 class="section-title">
                    <i class="fas fa-calendar-check"></i>
                    Agenda des Cours
                </h1>
                <div class="header-icon">
                    <span class="emoji">📅</span>
                </div>
            </div>

            <!-- Page Description -->
            <div class="description-section">
                <p class="description-text">
                    Votre agenda personnalisé avec notifications pour chaque cours
                </p>
            </div>

            <!-- Quick Stats -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-book"></i>
                    </div>
                    <div class="stat-content">
                        <h4>Total Cours</h4>
                        <p class="stat-value">{{ coursAVoir|length }}</p>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-bell"></i>
                    </div>
                    <div class="stat-content">
                        <h4>Notifications</h4>
                        <p class="stat-value">{{ notifications|length }}</p>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="stat-content">
                        <h4>Aujourd'hui</h4>
                        <p class="stat-value">{{ "now"|date("d F") }}</p>
                    </div>
                </div>
            </div>

            <!-- Notifications Section -->
            {% if notifications|length > 0 %}
            <div class="notifications-section">
                <div class="section-header">
                    <h2 class="section-subtitle">
                        <i class="fas fa-bell"></i> Notifications
                    </h2>
                </div>

                <div class="notifications-grid">
                    {% for notification in notifications %}
                        <div class="notification-card notification-{{ notification.type }} notification-{{ notification.priorite }}">
                            <div class="notification-header">
                                <div class="notification-icon">
                                    {% if notification.type == 'en_cours' %}
                                        <i class="fas fa-play-circle"></i>
                                    {% elseif notification.type == 'imminent' %}
                                        <i class="fas fa-exclamation-circle"></i>
                                    {% elseif notification.type == 'proche' %}
                                        <i class="fas fa-clock"></i>
                                    {% else %}
                                        <i class="fas fa-calendar-alt"></i>
                                    {% endif %}
                                </div>
                                <div class="notification-time">
                                    <span class="badge badge-{{ notification.priorite }}">{{ notification.priorite|upper }}</span>
                                </div>
                            </div>
                            
                            <div class="notification-body">
                                <h4 class="notification-title">{{ notification.matiere }}</h4>
                                <p class="notification-message">{{ notification.message }}</p>
                                <div class="notification-schedule">
                                    <span><i class="fas fa-calendar-day"></i> {{ notification.jour }}</span>
                                    <span><i class="fas fa-clock"></i> {{ notification.heureDebut }} - {{ notification.heureFin }}</span>
                                </div>
                            </div>
                            
                            {% if notification.conseils|length > 0 %}
                            <div class="notification-tips">
                                <h5><i class="fas fa-lightbulb"></i> Conseils pour {{ notification.matiere }}</h5>
                                <ul>
                                    {% for conseil in notification.conseils %}
                                        <li>{{ conseil }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <!-- Schedule Grid -->
            <div class="schedule-section">
                <div class="section-header">
                    <h2 class="section-subtitle">
                        <i class="fas fa-calendar-week"></i> Emploi du Temps
                    </h2>
                </div>

                <!-- Filter Form -->
                <div class="filter-form">
                    <form method="GET" action="{{ path('app_stresse_agenda') }}">
                        <div class="filter-grid">
                            <div class="form-group">
                                <label for="matiere_par_jour">
                                    <i class="fas fa-book"></i> Matières par jour
                                </label>
                                <input type="number" id="matiere_par_jour" name="matiere_par_jour" 
                                       class="form-control" min="1" max="8" 
                                       value="{{ parametres.matiereParJour }}">
                            </div>
                            
                            <div class="form-group">
                                <label for="heure_debut">
                                    <i class="fas fa-sun"></i> Heure de début
                                </label>
                                <input type="number" id="heure_debut" name="heure_debut" 
                                       class="form-control" min="6" max="22" 
                                       value="{{ parametres.heureDebut }}">
                            </div>
                            
                            <div class="form-group">
                                <label for="periode">
                                    <i class="fas fa-calendar-week"></i> Période
                                </label>
                                <select id="periode" name="periode" class="form-control">
                                    <option value="semaine" {% if parametres.periode == 'semaine' %}selected{% endif %}>Semaine</option>
                                    <option value="quinzaine" {% if parametres.periode == 'quinzaine' %}selected{% endif %}>Quinzaine</option>
                                    <option value="mois" {% if parametres.periode == 'mois' %}selected{% endif %}>Mois</option>
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label for="niveau_stress">
                                    <i class="fas fa-heartbeat"></i> Niveau de stress
                                </label>
                                <input type="range" id="niveau_stress" name="niveau_stress" 
                                       class="form-control-range" min="1" max="10" 
                                       value="{{ parametres.niveauStress }}">
                            </div>
                        </div>
                        
                        <div class="form-actions">
                            <button type="submit" class="btn-filter">
                                <i class="fas fa-sync-alt"></i> Actualiser l'agenda
                            </button>
                            <a href="{{ path('app_stresse_emploie_avance') }}" class="btn-secondary">
                                <i class="fas fa-cog"></i> Paramètres avancés
                            </a>
                        </div>
                    </form>
                </div>

                <!-- Schedule Display -->
                <div class="schedule-grid">
                    {% set joursSemaine = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi'] %}
                    {% if parametres.inclureWeekend %}
                        {% set joursSemaine = joursSemaine|merge(['Samedi', 'Dimanche']) %}
                    {% endif %}
                    
                    {% for jour in joursSemaine %}
                        <div class="day-column {% if jour == "now"|date('l')|replace({'Monday': 'Lundi', 'Tuesday': 'Mardi', 'Wednesday': 'Mercredi', 'Thursday': 'Jeudi', 'Friday': 'Vendredi', 'Saturday': 'Samedi', 'Sunday': 'Dimanche'}) %}today{% endif %}">
                            <div class="day-header">
                                <span class="day-name">{{ jour }}</span>
                            </div>
                            
                            <div class="day-courses">
                                {% if emploiTemps[jour] is defined %}
                                    {% for cours in emploiTemps[jour] %}
                                        <div class="course-card">
                                            <div class="course-time">
                                                <i class="fas fa-clock"></i>
                                                {{ cours.heureDebut }} - {{ cours.heureFin }}
                                            </div>
                                            <div class="course-matiere">
                                                {{ cours.matiere }}
                                            </div>
                                            <div class="course-efficiency">
                                                <span class="efficiency-badge efficiency-{{ cours.efficacite|lower }}">
                                                    {{ cours.efficacite }}
                                                </span>
                                            </div>
                                        </div>
                                    {% endfor %}
                                {% else %}
                                    <div class="no-courses">
                                        <i class="fas fa-coffee"></i>
                                        <span>Aucun cours</span>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Upcoming Courses -->
            <div class="upcoming-section">
                <div class="section-header">
                    <h2 class="section-subtitle">
                        <i class="fas fa-forward"></i> Cours à Venir
                    </h2>
                </div>

                <div class="upcoming-list">
                    {% for cours in coursAVoir %}
                        <div class="upcoming-card {% if cours.estAujourdhui %}today{% endif %}">
                            <div class="upcoming-date">
                                {% if cours.estAujourdhui %}
                                    <span class="date-label">Aujourd'hui</span>
                                {% else %}
                                    <span class="date-label">{{ cours.jour }}</span>
                                {% endif %}
                            </div>
                            <div class="upcoming-info">
                                <h4>{{ cours.matiere }}</h4>
                                <p>
                                    <i class="fas fa-clock"></i>
                                    {{ cours.heureDebut }} - {{ cours.heureFin }}
                                </p>
                            </div>
                            <div class="upcoming-efficiency">
                                <span class="efficiency-badge efficiency-{{ cours.efficacite|lower }}">
                                    {{ cours.efficacite }}
                                </span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a href="{{ path('app_stresse_emploie_avance', {
                    'matiere_par_jour': parametres.matiereParJour,
                    'heure_par_matiere': parametres.heureParMatiere,
                    'pause': parametres.pause,
                    'heure_debut': parametres.heureDebut,
                    'periode': parametres.periode,
                    'inclure_weekend': parametres.inclureWeekend ? 1 : 0,
                    'niveau_stress': parametres.niveauStress,
                    'matieres': matieres|join(',')
                }) }}" class="btn-action">
                    <i class="fas fa-plus-circle"></i>
                    Modifier les paramètres
                </a>
                <a href="{{ path('app_stresse_coach') }}" class="btn-action btn-secondary">
                    <i class="fas fa-user-tie"></i>
                    Voir les conseils anti-stress
                </a>
            </div>
        </div>
    </div>

    <!-- Styles -->
    {% block stylesheets %}
        {{ parent() }}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { font-family: 'Inter', 'Segoe UI', sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
            .header-area { background: rgba(0, 0, 0, 0.3) !important; backdrop-filter: blur(10px); }
            .header-area .logo h1, .header-area .nav a, .header-area .menu-trigger span, nav, .navbar, nav *, .navbar *, .nav-link { color: white !important; }
            .agenda-section { padding: 120px 20px 60px 20px; background-color: transparent; min-height: 100vh; }
            .container { max-width: 1400px; margin: 0 auto; }
            .section-title { font-size: 2.5rem; font-weight: 700; color: #ffffff; text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2); margin: 0; display: flex; align-items: center; gap: 15px; }
            .section-subtitle { font-size: 1.5rem; font-weight: 700; color: #ffffff; text-align: center; margin-bottom: 30px; text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2); display: flex; align-items: center; justify-content: center; gap: 10px; }
            .description-text { font-size: 1.2rem; color: rgba(255, 255, 255, 0.9); max-width: 800px; margin: 0 auto; line-height: 1.6; text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2); }
            .header-with-button { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
            .header-icon { background: rgba(255, 255, 255, 0.2); border-radius: 50%; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
            .header-icon .emoji { font-size: 2rem; }
            .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
            .stat-card { background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); border-radius: 15px; padding: 20px; display: flex; align-items: center; gap: 15px; transition: transform 0.3s ease; }
            .stat-card:hover { transform: translateY(-5px); }
            .stat-icon { background: rgba(255, 255, 255, 0.2); border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: white; }
            .stat-content h4 { color: rgba(255, 255, 255, 0.8); font-size: 0.9rem; margin-bottom: 5px; }
            .stat-value { color: white; font-size: 1.8rem; font-weight: 700; }
            
            /* Notifications */
            .notifications-section { margin-bottom: 40px; }
            .notifications-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
            .notification-card { background: rgba(255, 255, 255, 0.95); border-radius: 15px; padding: 20px; transition: transform 0.3s ease, box-shadow 0.3s ease; }
            .notification-card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2); }
            .notification-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
            .notification-icon { font-size: 2rem; color: #667eea; }
            .notification-title { font-size: 1.2rem; font-weight: 700; color: #333; margin-bottom: 10px; }
            .notification-message { color: #666; font-size: 0.95rem; margin-bottom: 10px; }
            .notification-schedule { display: flex; gap: 15px; color: #888; font-size: 0.85rem; }
            .notification-schedule i { margin-right: 5px; }
            .notification-tips { margin-top: 15px; padding-top: 15px; border-top: 1px solid #eee; }
            .notification-tips h5 { color: #667eea; font-size: 0.9rem; margin-bottom: 10px; }
            .notification-tips ul { padding-left: 20px; color: #666; font-size: 0.85rem; }
            .notification-tips li { margin-bottom: 5px; }
            
            /* Badge colors */
            .badge { padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
            .badge-haute { background: #ff4757; color: white; }
            .badge-moyenne { background: #ffa502; color: white; }
            .badge-basse { background: #2ed573; color: white; }
            
            /* Notification type colors */
            .notification-en_cours { border-left: 4px solid #ff4757; }
            .notification-imminent { border-left: 4px solid #ffa502; }
            .notification-proche { border-left: 4px solid #ffa502; }
            .notification-avenir { border-left: 4px solid #2ed573; }
            
            /* Schedule */
            .schedule-section { margin-bottom: 40px; }
            .filter-form { background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); border-radius: 15px; padding: 25px; margin-bottom: 30px; }
            .filter-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
            .filter-form .form-group label { display: block; color: white; margin-bottom: 8px; font-weight: 500; }
            .filter-form .form-group label i { margin-right: 8px; }
            .filter-form .form-control { width: 100%; padding: 12px 15px; border: none; border-radius: 10px; font-size: 1rem; background: rgba(255, 255, 255, 0.9); }
            .filter-form .form-control-range { width: 100%; }
            .form-actions { display: flex; gap: 15px; margin-top: 20px; flex-wrap: wrap; }
            .btn-filter { background: #2ed573; color: white; border: none; padding: 12px 25px; border-radius: 10px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; gap: 8px; }
            .btn-filter:hover { background: #26af61; transform: translateY(-2px); }
            .btn-secondary { background: rgba(255, 255, 255, 0.2); color: white; border: none; padding: 12px 25px; border-radius: 10px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; gap: 8px; text-decoration: none; }
            .btn-secondary:hover { background: rgba(255, 255, 255, 0.3); transform: translateY(-2px); }
            
            /* Schedule Grid */
            .schedule-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 15px; }
            @media (max-width: 1200px) { .schedule-grid { grid-template-columns: repeat(3, 1fr); } }
            @media (max-width: 768px) { .schedule-grid { grid-template-columns: repeat(2, 1fr); } }
            @media (max-width: 480px) { .schedule-grid { grid-template-columns: 1fr; } }
            
            .day-column { background: rgba(255, 255, 255, 0.95); border-radius: 15px; overflow: hidden; }
            .day-column.today { box-shadow: 0 0 20px rgba(46, 213, 115, 0.5); }
            .day-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 15px; text-align: center; }
            .day-column.today .day-header { background: linear-gradient(135deg, #2ed573 0%, #26af61 100%); }
            .day-name { color: white; font-weight: 700; font-size: 1rem; }
            .day-courses { padding: 10px; min-height: 200px; }
            .course-card { background: #f8f9fa; border-radius: 10px; padding: 12px; margin-bottom: 10px; transition: transform 0.3s ease; }
            .course-card:hover { transform: scale(1.02); }
            .course-time { color: #667eea; font-size: 0.85rem; font-weight: 600; margin-bottom: 5px; }
            .course-time i { margin-right: 5px; }
            .course-matiere { color: #333; font-weight: 600; font-size: 0.95rem; margin-bottom: 5px; }
            .efficiency-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; }
            .efficiency-haute { background: #ff4757; color: white; }
            .efficiency-normale { background: #ffa502; color: white; }
            .efficiency-basse { background: #2ed573; color: white; }
            .no-courses { text-align: center; padding: 30px 10px; color: #999; }
            .no-courses i { font-size: 2rem; margin-bottom: 10px; display: block; }
            
            /* Upcoming */
            .upcoming-section { margin-bottom: 40px; }
            .upcoming-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; }
            .upcoming-card { background: rgba(255, 255, 255, 0.95); border-radius: 15px; padding: 20px; display: flex; align-items: center; gap: 15px; transition: transform 0.3s ease; }
            .upcoming-card:hover { transform: translateY(-5px); }
            .upcoming-card.today { border-left: 4px solid #2ed573; }
            .upcoming-date { min-width: 80px; }
            .date-label { display: block; color: #667eea; font-weight: 700; font-size: 0.9rem; }
            .upcoming-info { flex: 1; }
            .upcoming-info h4 { color: #333; font-size: 1rem; margin-bottom: 5px; }
            .upcoming-info p { color: #666; font-size: 0.85rem; }
            .upcoming-info p i { margin-right: 5px; }
            
            /* Action Buttons */
            .action-buttons { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
            .btn-action { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; padding: 15px 30px; border-radius: 15px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; gap: 10px; text-decoration: none; }
            .btn-action:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4); }
            .btn-action.btn-secondary { background: rgba(255, 255, 255, 0.2); }
            .btn-action.btn-secondary:hover { background: rgba(255, 255, 255, 0.3); }
        </style>
    {% endblock %}
{% endblock %}
