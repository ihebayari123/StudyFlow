<!-- Font Awesome for Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<script>
    // Filter functionality
    document.querySelectorAll('.filter-btn').forEach(button => {
        button.addEventListener('click', function() {
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            this.classList.add('active');
        });
    });

    // Search functionality
    document.getElementById('searchInput').addEventListener('keyup', function() {
        const searchValue = this.value.toLowerCase();
        const bilanCards = document.querySelectorAll('.bilan-card');

        bilanCards.forEach(card => {
            const studentName = card.querySelector('.student-name').textContent.toLowerCase();
            const doctorComment = card.querySelector('.doctor-comment span').textContent.toLowerCase();
            
            if (studentName.includes(searchValue) || doctorComment.includes(searchValue)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    });
</script>
