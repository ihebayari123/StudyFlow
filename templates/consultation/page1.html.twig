{% extends 'base.html.twig' %}

{% block title %}Santé & Bien-être{% endblock %}

{% block body %}
    <!-- Header -->
    {% block header %}
        {% include 'home/navbar.html.twig' %}
    {% endblock %}

    <!-- Main Content -->
    <div class="courses-section">
        <div class="container">
            <!-- Page Header -->
            <div class="header-with-button">
                <h1 class="section-title">Santé & Bien-être</h1>
                <div class="header-actions">
                    {# Statistiques - désactivé #}
                </div>
            </div>

            <!-- Page Description -->
            <div class="description-section">
                <p class="description-text">
                    Choisissez votre service de santé préféré et accédez à vos consultations médicales 
                    ou visualisez vos scores de santé personnalisés.
                </p>
            </div>

            <!-- Services Grid -->
            <div class="services-grid">
                <!-- Service: Consultation Médicale -->
                <div class="service-card">
                    <div class="service-image">
                        <div class="service-logo">
                            <div class="logo-container logo-primary">
                                <i class="fas fa-heartbeat"></i>
                            </div>
                        </div>
                        <span class="service-category">Consulte_Medecin</span>
                        <div class="service-actions">
                            <a href="{{ path('app_add_consultation') }}" class="action-btn doctor-btn" title="Consulter">
                                <i class="fas fa-user-md"></i>
                            </a>
                        </div>
                    </div>
                    <div class="service-content">
                        <h3 class="service-title">Consulte_Medecin</h3>
                        <p class="service-description">
                            Service complet de santé avec suivi médical personnalisé.
                        </p>
                    </div>
                </div>

                <!-- Service: Score de Santé -->
                <div class="service-card">
                    <div class="service-image">
                        <div class="service-logo">
                            <div class="logo-container logo-secondary">
                                <i class="fas fa-brain"></i>
                            </div>
                        </div>
                        <span class="service-category">Voir_score</span>
                        <div class="service-actions">
                            <a href="{{ path('app_add_stresse') }}" class="action-btn doctor-btn" title="Consulter">
                                <i class="fas fa-user-md"></i>
                            </a>
                        </div>
                    </div>
                    <div class="service-content">
                        <h3 class="service-title">Voir_score</h3>
                        <p class="service-description">
                            Support psychologique et gestion du stress.
                        </p>
                    </div>
                </div>

                <!-- Service: Coach Stresse -->
                <div class="service-card">
                    <div class="service-image">
                        <div class="service-logo">
                            <div class="logo-container" style="background: linear-gradient(135deg, #FF6B6B 0%, #C92A2A 100%);">
                                <i class="fas fa-spa"></i>
                            </div>
                        </div>
                        <span class="service-category">COACH_STRESSE</span>
                        <div class="service-actions">
                            <a href="{{ path('app_stresse_coach') }}" class="action-btn" style="background: linear-gradient(135deg, #FF6B6B 0%, #C92A2A 100%);" title="Consulter coach">
                                <i class="fas fa-user-tie"></i>
                            </a>
                        </div>
                    </div>
                    <div class="service-content">
                        <h3 class="service-title">Coach Stresse</h3>
                        <p class="service-description">
                            Accompagnement personnalisé pour la gestion du stress et l'équilibre émotionnel.
                        </p>
                    </div>
                </div>

                <!-- Service: Nutrition -->
                <div class="service-card">
                    <div class="service-image">
                        <div class="service-logo">
                            <div class="logo-container logo-tertiary">
                                <i class="fas fa-apple-alt"></i>
                            </div>
                        </div>
                        <span class="service-category">NUTRITION</span>
                        <div class="service-actions">
                            <a href="/stresse/jeux" class="action-btn score-btn" title="Consulter jeu">
                                <i class="fas fa-gamepad"></i>
                            </a>
                        </div>
                    </div>
                    <div class="service-content">
                        <a href="{{ path('app_studyflow_nutrition') }}" class="service-link">
                            <h3 class="service-title">Nutrition</h3>
                            <p class="service-description">
                                Plans nutritionnels personnalisés.
                            </p>
                        </a>
                    </div>
                </div>

                <!-- Service: Fitness -->
                <div class="service-card">
                    <div class="service-image">
                        <div class="service-logo">
                            <div class="logo-container logo-quaternary">
                                <i class="fas fa-dumbbell"></i>
                            </div>
                        </div>
                        <span class="service-category">FITNESS</span>
                        <div class="service-actions">
                            <a href="{{ path('app_studyflow_fitness') }}" class="action-btn doctor-btn" title="Consulter">
                                <i class="fas fa-user-md"></i>
                            </a>
                        </div>
                    </div>
                    <div class="service-content">
                        <h3 class="service-title">Fitness</h3>
                        <p class="service-description">
                            Programmes d'entraînement personnalisés.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Statistics Section -->
            <div class="stats-section">
                <h2 class="section-subtitle">Vos Statistiques</h2>
                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-icon">
                            <i class="fas fa-heart"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-value">92%</h3>
                            <p>Santé Globale</p>
                        </div>
                    </div>
                    
                    <div class="stat-item">
                        <div class="stat-icon">
                            <i class="fas fa-smile"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-value">85%</h3>
                            <p>Bien-être</p>
                        </div>
                    </div>
                    
                    <div class="stat-item">
                        <div class="stat-icon">
                            <i class="fas fa-utensils"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-value">78%</h3>
                            <p>Nutrition</p>
                        </div>
                    </div>
                    
                    <div class="stat-item">
                        <div class="stat-icon">
                            <i class="fas fa-running"></i>
                        </div>
                        <div class="stat-content">
                            <h3 class="stat-value">90%</h3>
                            <p>Activité</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bouton flottant pour générer emploi du temps -->
    <a href="{{ path('app_stresse_emploie_avance') }}" class="schedule-floating-btn" title="Générer emploi du temps">
        <i class="fas fa-calendar-alt"></i>
        <span class="btn-text">Générer emploi du temps</span>
    </a>

    <!-- Robot X Floating Button -->
    <button class="robot-floating-btn" id="robotToggleBtn" title="Discuter avec Robot X">
        <i class="fas fa-robot"></i>
        <span class="btn-text">Robot X</span>
    </button>

    <!-- Robot X Chat Interface -->
    <div class="robot-chat-container" id="robotChatContainer">
        <div class="robot-chat-header">
            <div class="robot-info">
                <i class="fas fa-robot"></i>
                <h3>Robot X - Assistant</h3>
            </div>
            <button class="close-chat-btn" id="closeChatBtn">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="robot-chat-messages" id="chatMessages">
            <!-- Messages will be added here dynamically -->
        </div>
        <div class="quick-actions">
            <button class="quick-action-btn" onclick="askAboutServices()">
                <i class="fas fa-list"></i> Services
            </button>
            <button class="quick-action-btn" onclick="askAboutConsultation()">
                <i class="fas fa-user-md"></i> Consultation
            </button>
            <button class="quick-action-btn" onclick="askAboutStress()">
                <i class="fas fa-brain"></i> Stress
            </button>
            <button class="quick-action-btn" onclick="askAboutNutrition()">
                <i class="fas fa-apple-alt"></i> Nutrition
            </button>
            <button class="quick-action-btn" onclick="askAboutFitness()">
                <i class="fas fa-dumbbell"></i> Fitness
            </button>
            <button class="quick-action-btn" onclick="askAboutStats()">
                <i class="fas fa-chart-line"></i> Statistiques
            </button>
        </div>
        <div class="robot-chat-input">
            <button id="testVoiceBtn" class="voice-ai-btn" title="Tester la voix" style="background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);">
                <i class="fas fa-volume-up"></i>
            </button>
            <button id="voiceAIBtn" class="voice-ai-btn" title="Activer la reconnaissance vocale">
                <i class="fas fa-microphone"></i>
            </button>
            <input type="text" id="userQuestion" placeholder="Posez votre question..." class="chat-input-field">
            <button id="sendQuestionBtn" class="send-btn">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>

    <!-- Notification de bienvenue -->
    <div class="welcome-notification" id="welcomeNotification">
        <div class="notification-content">
            <div class="notification-icon">
                <i class="fas fa-robot"></i>
            </div>
            <div class="notification-text">
                <h4>Bonjour ! 👋</h4>
                <p>Je suis Robot X, votre assistant personnel. Besoin d'aide ?</p>
            </div>
            <button class="notification-close" onclick="closeNotification()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="notification-progress"></div>
    </div>

    <!-- Voice Status Indicator -->
    <div class="voice-status" id="voiceStatus">
        <i class="fas fa-microphone"></i> <span id="voiceStatusText">En attente...</span>
    </div>

    <!-- Conteneur pour les notifications de motivation -->
    <div class="motivation-notification-container" id="motivationNotification"></div>

    <!-- Styles -->
    {% block stylesheets %}
        {{ parent() }}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <style>
            /* Reset & Base */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                min-height: 100vh;
            }

            /* Header */
            .header-area {
                background: rgba(0, 0, 0, 0.3) !important;
                backdrop-filter: blur(10px);
            }

            .header-area .logo h1,
            .header-area .nav a,
            .header-area .menu-trigger span,
            nav, .navbar, nav *, .navbar *, .nav-link {
                color: white !important;
            }

            /* Layout */
            .courses-section {
                padding: 120px 20px 60px 20px;
                background-color: transparent;
                min-height: 100vh;
            }

            .container {
                max-width: 1400px;
                margin: 0 auto;
            }

            /* Typography */
            .section-title {
                font-size: 3rem;
                font-weight: 700;
                color: #ffffff;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
                margin: 0;
            }

            .section-subtitle {
                font-size: 2rem;
                font-weight: 700;
                color: #ffffff;
                text-align: center;
                margin-bottom: 40px;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
            }

            .description-text {
                font-size: 1.2rem;
                color: rgba(255, 255, 255, 0.9);
                max-width: 800px;
                margin: 0 auto;
                line-height: 1.6;
                text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
            }

            /* Header with Button */
            .header-with-button {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 50px;
                flex-wrap: wrap;
                gap: 20px;
            }

            /* Description Section */
            .description-section {
                margin-bottom: 60px;
                text-align: center;
            }

            /* Services Grid */
            .services-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
                gap: 30px;
                margin-bottom: 60px;
            }

            .service-card {
                background: white;
                border-radius: 20px;
                overflow: hidden;
                transition: all 0.3s ease;
                cursor: pointer;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            }

            .service-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            }

            .service-image {
                position: relative;
                height: 250px;
                overflow: hidden;
                background: linear-gradient(135deg, #f0f4ff 0%, #e6e9ff 100%);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .service-logo {
                text-align: center;
            }

            .logo-container {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
                font-size: 2.5rem;
                color: white;
                box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            }

            .logo-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
            .logo-secondary { background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%); }
            .logo-tertiary { background: linear-gradient(135deg, #FF9800 0%, #FF5722 100%); }
            .logo-quaternary { background: linear-gradient(135deg, #2196F3 0%, #0D47A1 100%); }

            .service-category {
                position: absolute;
                top: 20px;
                left: 20px;
                background: white;
                color: #7b68ee;
                padding: 10px 25px;
                border-radius: 25px;
                font-weight: 600;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            /* Action Buttons */
            .service-actions {
                position: absolute;
                bottom: 20px;
                right: 20px;
                display: flex;
                gap: 10px;
                opacity: 0;
                transition: opacity 0.3s ease;
            }

            .service-card:hover .service-actions {
                opacity: 1;
            }

            .action-btn {
                width: 45px;
                height: 45px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
                transition: all 0.3s ease;
                font-size: 1.1rem;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            }

            .doctor-btn {
                background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
                color: white;
            }

            .doctor-btn:hover {
                transform: scale(1.1);
                box-shadow: 0 6px 15px rgba(76, 175, 80, 0.4);
            }

            .score-btn {
                background: linear-gradient(135deg, #2196F3 0%, #0D47A1 100%);
                color: white;
            }

            .score-btn:hover {
                transform: scale(1.1);
                box-shadow: 0 6px 15px rgba(33, 150, 243, 0.4);
            }

            /* Service Content */
            .service-content {
                padding: 25px 30px 30px;
                background: white;
            }

            .service-link {
                text-decoration: none;
                color: inherit;
                display: block;
            }

            .service-title {
                color: #1a1a1a;
                font-size: 1.8rem;
                font-weight: 700;
                margin-bottom: 15px;
                text-align: center;
            }

            .service-description {
                color: #666;
                font-size: 1rem;
                line-height: 1.6;
                text-align: center;
            }

            /* Stats Section */
            .stats-section {
                margin-top: 60px;
                padding: 40px;
                background: rgba(255, 255, 255, 0.1);
                border-radius: 20px;
                backdrop-filter: blur(10px);
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .stats-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
                gap: 30px;
            }

            .stat-item {
                background: rgba(255, 255, 255, 0.15);
                border-radius: 15px;
                padding: 25px;
                display: flex;
                align-items: center;
                gap: 20px;
                transition: all 0.3s ease;
                border: 2px solid rgba(255, 255, 255, 0.1);
            }

            .stat-item:hover {
                background: rgba(255, 255, 255, 0.25);
                transform: translateY(-5px);
            }

            .stat-icon {
                width: 60px;
                height: 60px;
                background: rgba(255, 255, 255, 0.2);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.8rem;
                color: white;
            }

            .stat-content h3 {
                font-size: 2.5rem;
                font-weight: 700;
                color: white;
                margin-bottom: 5px;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
            }

            .stat-content p {
                color: rgba(255, 255, 255, 0.9);
                font-size: 1rem;
                font-weight: 500;
            }

            /* Style du bouton flottant pour emploi du temps */
            .schedule-floating-btn {
                position: fixed;
                bottom: 30px;
                right: 30px;
                background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
                color: white;
                width: 60px;
                height: 60px;
                border-radius: 30px;
                display: flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
                box-shadow: 0 4px 15px rgba(255, 152, 0, 0.3);
                transition: all 0.3s ease;
                z-index: 1000;
                overflow: hidden;
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .schedule-floating-btn i {
                font-size: 1.8rem;
                transition: all 0.3s ease;
            }

            .schedule-floating-btn .btn-text {
                position: absolute;
                white-space: nowrap;
                opacity: 0;
                transform: translateX(20px);
                transition: all 0.3s ease;
                font-weight: 600;
                font-size: 1rem;
            }

            .schedule-floating-btn:hover {
                width: 220px;
                background: linear-gradient(135deg, #F57C00 0%, #EF6C00 100%);
                box-shadow: 0 8px 25px rgba(255, 152, 0, 0.4);
            }

            .schedule-floating-btn:hover i {
                transform: translateX(-40px);
            }

            .schedule-floating-btn:hover .btn-text {
                opacity: 1;
                transform: translateX(0);
            }

            /* Robot X Floating Button */
            .robot-floating-btn {
                position: fixed;
                bottom: 30px;
                right: 100px;
                background: linear-gradient(135deg, #00BCD4 0%, #0097A7 100%);
                color: white;
                width: 60px;
                height: 60px;
                border-radius: 30px;
                display: flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
                box-shadow: 0 4px 15px rgba(0, 188, 212, 0.3);
                transition: all 0.3s ease;
                z-index: 1000;
                overflow: hidden;
                border: none;
                cursor: pointer;
                border: 2px solid rgba(255, 255, 255, 0.2);
            }

            .robot-floating-btn i {
                font-size: 1.8rem;
                transition: all 0.3s ease;
            }

            .robot-floating-btn .btn-text {
                position: absolute;
                white-space: nowrap;
                opacity: 0;
                transform: translateX(20px);
                transition: all 0.3s ease;
                font-weight: 600;
                font-size: 1rem;
            }

            .robot-floating-btn:hover {
                width: 150px;
                background: linear-gradient(135deg, #0097A7 0%, #006064 100%);
                box-shadow: 0 8px 25px rgba(0, 188, 212, 0.4);
            }

            .robot-floating-btn:hover i {
                transform: translateX(-40px);
            }

            .robot-floating-btn:hover .btn-text {
                opacity: 1;
                transform: translateX(0);
            }

            /* Robot X Chat Container */
            .robot-chat-container {
                position: fixed;
                bottom: 100px;
                right: 100px;
                width: 380px;
                height: 550px;
                background: white;
                border-radius: 20px;
                box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
                display: none;
                flex-direction: column;
                overflow: hidden;
                z-index: 1001;
                animation: slideIn 0.3s ease;
            }

            .robot-chat-container.active {
                display: flex;
            }

            @keyframes slideIn {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .robot-chat-header {
                background: linear-gradient(135deg, #00BCD4 0%, #0097A7 100%);
                color: white;
                padding: 15px 20px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .robot-info {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .robot-info i {
                font-size: 1.5rem;
            }

            .robot-info h3 {
                font-size: 1.1rem;
                font-weight: 600;
                margin: 0;
            }

            .close-chat-btn {
                background: none;
                border: none;
                color: white;
                font-size: 1.2rem;
                cursor: pointer;
                width: 30px;
                height: 30px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: background 0.3s ease;
            }

            .close-chat-btn:hover {
                background: rgba(255, 255, 255, 0.2);
            }

            .robot-chat-messages {
                flex: 1;
                padding: 20px;
                overflow-y: auto;
                background: #f5f5f5;
            }

            .message {
                margin-bottom: 15px;
                display: flex;
                flex-direction: column;
            }

            .message.user {
                align-items: flex-end;
            }

            .message.robot {
                align-items: flex-start;
            }

            .message-content {
                max-width: 80%;
                padding: 10px 15px;
                border-radius: 18px;
                font-size: 0.95rem;
                line-height: 1.4;
            }

            .message.user .message-content {
                background: linear-gradient(135deg, #00BCD4 0%, #0097A7 100%);
                color: white;
                border-bottom-right-radius: 5px;
            }

            .message.robot .message-content {
                background: white;
                color: #333;
                border-bottom-left-radius: 5px;
                box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            }

            .message-time {
                font-size: 0.7rem;
                color: #999;
                margin-top: 5px;
                margin-left: 5px;
                margin-right: 5px;
            }

            /* Quick Actions */
            .quick-actions {
                padding: 10px;
                background: white;
                border-bottom: 1px solid #eee;
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                justify-content: center;
            }

            .quick-action-btn {
                background: #f0f0f0;
                border: none;
                padding: 8px 12px;
                border-radius: 20px;
                font-size: 0.8rem;
                color: #333;
                cursor: pointer;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                gap: 5px;
            }

            .quick-action-btn:hover {
                background: linear-gradient(135deg, #00BCD4 0%, #0097A7 100%);
                color: white;
                transform: translateY(-2px);
            }

            .robot-chat-input {
                padding: 15px;
                background: white;
                border-top: 1px solid #eee;
                display: flex;
                gap: 10px;
            }

            .chat-input-field {
                flex: 1;
                padding: 10px 15px;
