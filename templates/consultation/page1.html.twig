                // Liste des messages de motivation
                const motivationMessages = [
                    "💪 Vous êtes formidable ! Continuez à prendre soin de vous !",
                    "🌟 Chaque petit pas compte dans votre parcours de bien-être !",
                    "🌈 Votre santé est votre plus grande richesse, prenez-en soin !",
                    "✨ Vous méritez d'être en pleine forme aujourd'hui !",
                    "🌱 Prenez un moment pour respirer et vous détendre.",
