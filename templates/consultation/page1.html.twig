                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.3s ease;
            }

            .send-btn:hover {
                transform: scale(1.1);
                box-shadow: 0 4px 10px rgba(0, 188, 212, 0.3);
            }

            /* Voice AI Button */
            .voice-ai-btn {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                background: linear-gradient(135deg, #9C27B0 0%, #7B1FA2 100%);
                color: white;
                border: none;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.3s ease;
                flex-shrink: 0;
            }

            .voice-ai-btn:hover {
                transform: scale(1.1);
                box-shadow: 0 4px 15px rgba(156, 39, 176, 0.4);
            }

            .voice-ai-btn.listening {
                animation: voicePulse 1.5s infinite;
                background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
            }

            .voice-ai-btn.speaking {
                animation: voicePulse 0.5s infinite;
                background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
            }

            @keyframes voicePulse {
                0% {
                    box-shadow: 0 0 0 0 rgba(156, 39, 176, 0.7);
                }
                70% {
                    box-shadow: 0 0 0 15px rgba(156, 39, 176, 0);
                }
                100% {
                    box-shadow: 0 0 0 0 rgba(156, 39, 176, 0);
                }
            }

            /* Voice Status Indicator */
            .voice-status {
                position: fixed;
                top: 20px;
                left: 50%;
                transform: translateX(-50%);
                background: linear-gradient(135deg, #9C27B0 0%, #7B1FA2 100%);
                color: white;
                padding: 12px 25px;
                border-radius: 25px;
                font-weight: 600;
                display: none;
                z-index: 10000;
                box-shadow: 0 4px 20px rgba(156, 39, 176, 0.4);
            }

            .voice-status.active {
                display: block;
                animation: statusSlideDown 0.3s ease;
            }

            @keyframes statusSlideDown {
                from {
                    opacity: 0;
                    transform: translateX(-50%) translateY(-20px);
                }
                to {
                    opacity: 1;
                    transform: translateX(-50%) translateY(0);
                }
            }

            /* Welcome Notification */
            .welcome-notification {
                position: fixed;
                top: 100px;
                right: 30px;
                width: 350px;
                background: white;
                border-radius: 15px;
                box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
                overflow: hidden;
                z-index: 1002;
                animation: slideDown 0.5s ease;
                cursor: pointer;
            }

            @keyframes slideDown {
                from {
                    opacity: 0;
                    transform: translateY(-20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .notification-content {
                padding: 20px;
                display: flex;
                align-items: center;
                gap: 15px;
                background: linear-gradient(135deg, #00BCD4 0%, #0097A7 100%);
                color: white;
            }

            .notification-icon {
                width: 40px;
                height: 40px;
                background: rgba(255, 255, 255, 0.2);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
            }

            .notification-text {
                flex: 1;
            }

            .notification-text h4 {
                font-size: 1rem;
                font-weight: 600;
                margin-bottom: 5px;
            }

            .notification-text p {
                font-size: 0.9rem;
                opacity: 0.9;
            }

            .notification-close {
                background: none;
                border: none;
                color: white;
                font-size: 1rem;
                cursor: pointer;
                width: 30px;
                height: 30px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: background 0.3s ease;
            }

            .notification-close:hover {
                background: rgba(255, 255, 255, 0.2);
            }

            .notification-progress {
                height: 3px;
                background: rgba(255, 255, 255, 0.5);
                width: 100%;
                animation: progress 5s linear forwards;
            }

            @keyframes progress {
                from {
                    width: 100%;
                }
                to {
                    width: 0%;
                }
            }

            /* Motivation Notification */
            .motivation-notification-container {
                position: fixed;
                top: 100px;
                right: 30px;
                z-index: 1003;
                display: flex;
                flex-direction: column;
                gap: 10px;
                pointer-events: none;
            }

            .motivation-notification {
                background: white;
                border-radius: 15px;
                box-shadow: 0 10px 30px rgba(0, 188, 212, 0.3);
                overflow: hidden;
                animation: slideInRight 0.5s ease, fadeOut 0.5s ease 4.5s forwards;
                width: 320px;
                pointer-events: auto;
                border-left: 5px solid #00BCD4;
            }

            @keyframes slideInRight {
                from {
                    opacity: 0;
                    transform: translateX(100px);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            @keyframes fadeOut {
                from {
                    opacity: 1;
                    transform: translateX(0);
                }
                to {
                    opacity: 0;
                    transform: translateX(100px);
                }
            }

            .motivation-content {
                padding: 15px;
                display: flex;
                align-items: center;
                gap: 12px;
                background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            }

            .motivation-icon {
                width: 40px;
                height: 40px;
                background: linear-gradient(135deg, #00BCD4 0%, #0097A7 100%);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 1.2rem;
                animation: bounce 2s infinite;
            }

            @keyframes bounce {
                0%, 100% { transform: scale(1); }
                50% { transform: scale(1.1); }
            }

            .motivation-text {
                flex: 1;
            }

            .motivation-text p {
                color: #333;
                font-size: 0.95rem;
                line-height: 1.4;
                margin: 0;
                font-weight: 500;
            }

            .motivation-time {
                font-size: 0.7rem;
                color: #999;
                margin-top: 5px;
            }

            /* Suggestion buttons */
            .suggestion-buttons {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                margin-top: 10px;
            }

            .suggestion-btn {
                background: #f0f0f0;
                border: none;
                padding: 8px 12px;
                border-radius: 15px;
                font-size: 0.85rem;
                color: #333;
                cursor: pointer;
                transition: all 0.3s ease;
            }

            .suggestion-btn:hover {
                background: #e0e0e0;
                transform: translateY(-2px);
            }

            /* Responsive */
            @media (max-width: 768px) {
                .header-with-button {
                    flex-direction: column;
                    text-align: center;
                }

                .section-title {
                    font-size: 2rem;
                }

                .description-text {
                    font-size: 1rem;
                    padding: 0 15px;
                }

                .services-grid {
                    grid-template-columns: 1fr;
                }

                .service-actions {
                    opacity: 1;
                }

                .stats-grid {
                    grid-template-columns: 1fr;
                }

                .stat-item {
                    flex-direction: column;
                    text-align: center;
                }

                .schedule-floating-btn,
                .robot-floating-btn {
                    bottom: 20px;
                    width: 50px;
                    height: 50px;
                }

                .schedule-floating-btn {
                    right: 20px;
                }

                .robot-floating-btn {
                    right: 80px;
                }

                .schedule-floating-btn i,
                .robot-floating-btn i {
                    font-size: 1.5rem;
                }

                .schedule-floating-btn:hover,
                .robot-floating-btn:hover {
                    width: 180px;
                }

                .robot-chat-container {
                    width: 300px;
                    height: 500px;
                    right: 20px;
                    bottom: 80px;
                }

                .welcome-notification,
                .motivation-notification {
                    width: 280px;
                    right: 20px;
                    top: 80px;
                }

                .motivation-notification-container {
                    right: 20px;
                }

                .quick-actions {
                    padding: 8px;
                }

                .quick-action-btn {
                    padding: 6px 10px;
                    font-size: 0.75rem;
                }
            }

            @media (max-width: 480px) {
                .courses-section {
                    padding: 100px 15px 40px 15px;
                }

                .service-image {
                    height: 200px;
                }

                .logo-container {
                    width: 80px;
                    height: 80px;
