                    "🚀 Vous êtes sur la bonne voie pour une vie plus saine !",
                    "🎯 Fixez-vous des objectifs et atteignez-les avec le sourire !",
                    "🌞 Une nouvelle journée, une nouvelle opportunité de briller !",
                    "🧘‍♂️ N'oubliez pas de prendre du temps pour vous aujourd'hui.",
                    "⭐ Vous êtes unique et précieux, ne l'oubliez jamais !",
                    "💫 Votre bien-être est notre priorité, ensemble nous sommes plus forts !",
                    "🎉 Célébrez chaque victoire, même les plus petites !",
                    "🌺 Prenez soin de votre corps, c'est le seul endroit où vous devez vivre.",
                    "🏃‍♂️ L'activité physique est un cadeau que vous faites à votre corps !",
                    "🥗 Une alimentation équilibrée est la clé d'une vie épanouie !",
                    "😊 Votre sourire est la plus belle des médecines !",
                    "💪 Vous êtes plus fort que vous ne le pensez !",
                    "🌸 La santé n'est pas une destination, c'est un voyage quotidien.",
                    "🌿 Chaque jour est une nouvelle chance de prendre soin de soi."
                ];

                // Index pour parcourir les messages
                let motivationIndex = 0;

                // Fonction pour afficher un message de motivation
                function showMotivationMessage() {
                    const message = motivationMessages[motivationIndex];
                    
                    // Créer l'élément de notification
                    const notification = document.createElement('div');
                    notification.className = 'motivation-notification';
                    
                    notification.innerHTML = `
                        <div class="motivation-content">
                            <div class="motivation-icon">
                                <i class="fas fa-robot"></i>
                            </div>
                            <div class="motivation-text">
                                <p>${message}</p>
                                <div class="motivation-time">
                                    <i class="far fa-clock"></i> ${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                                </div>
                            </div>
                        </div>
                    `;
                    
                    // Ajouter au conteneur
                    motivationContainer.appendChild(notification);
                    
                    // Supprimer après 5 secondes
                    setTimeout(() => {
                        notification.remove();
                    }, 5000);
                    
                    // Passer au message suivant
                    motivationIndex = (motivationIndex + 1) % motivationMessages.length;
                }

                // Démarrer l'envoi de messages toutes les 1 minute (60000 ms)
                setInterval(showMotivationMessage, 60000);

                // Réponses par défaut
                const defaultResponses = [
                    "Je ne suis pas sûr de comprendre. Pouvez-vous reformuler votre question ?",
                    "Désolé, je n'ai pas d'information sur ce sujet. Essayez de me poser une question sur les services disponibles.",
                    "Je n'ai pas encore appris cela. Posez-moi plutôt des questions sur les fonctionnalités de cette page.",
                    "Je ne connais pas la réponse à cette question. Vous pouvez me demander sur les services : consultations, scores, coach stress, nutrition, fitness, statistiques ou emploi du temps."
                ];

                // Afficher la notification de bienvenue
                setTimeout(() => {
                    if (welcomeNotification) {
                        welcomeNotification.style.display = 'block';
                        
                        // Auto-fermeture après 5 secondes
                        setTimeout(() => {
                            closeNotification();
                        }, 5000);
                    }
                }, 1000);

                // Auto-greeting vocal when page loads
                setTimeout(() => {
                    // Open chat first
                    openChat();
                    
                    const greetingText = 'Bonjour ! Je suis Robot X, votre assistant vocal. Cliquez sur le bouton mikrophone pour me parler. Je peux vous dire bonjour, répondre comment ça va, ou expliquer le contenu de cette page.';
                    speakText(greetingText);
                    
                    // Also add message to chat
                    addMessage('robot', '🎤 **Bonjour !** Je suis votre assistant vocal.\n\nCliquez sur le bouton mikrophone violet pour me parler !\n\nJe peux répondre à :\n• "bonjour" - Je dis bonjour\n• "comment ça va" - Je vais bien\n• "explique le contenu de cette page" - Je vous explique tout\n• Questions sur les services');
                }, 2000);

                // Ajouter un message de bienvenue dans le chat
                setTimeout(() => {
                    addMessage('robot', '👋 Bonjour ! Je suis **Robot X**, votre assistant personnel. Je peux vous expliquer en détail toutes les fonctionnalités de cette page.\n\nUtilisez les boutons rapides ci-dessus ou posez-moi directement vos questions sur :\n• Les services disponibles\n• Comment consulter un médecin\n• Vos scores de santé\n• Le coach stress\n• La nutrition\n• Le fitness\n• Les statistiques\n• L\'emploi du temps');
                }, 1500);

                // Fonction pour fermer la notification
                window.closeNotification = function() {
                    if (welcomeNotification) {
                        welcomeNotification.style.display = 'none';
                    }
                };

                // Cliquer sur la notification ouvre le chat
                welcomeNotification.addEventListener('click', function(e) {
                    if (!e.target.classList.contains('notification-close') && !e.target.closest('.notification-close')) {
                        openChat();
                        closeNotification();
                    }
                });

                // Fonction pour ouvrir le chat
                function openChat() {
                    robotChatContainer.classList.add('active');
                }

                // Fonction pour fermer le chat
                function closeChat() {
                    robotChatContainer.classList.remove('active');
                }

                // Toggle du chat
                robotToggleBtn.addEventListener('click', function() {
                    if (robotChatContainer.classList.contains('active')) {
                        closeChat();
                    } else {
                        openChat();
                    }
                });

                // Fermer le chat
                closeChatBtn.addEventListener('click', closeChat);

                // Fonction pour ajouter un message
                function addMessage(sender, text) {
                    const messageDiv = document.createElement('div');
                    messageDiv.className = `message ${sender}`;
                    
                    const contentDiv = document.createElement('div');
                    contentDiv.className = 'message-content';
                    
                    // Remplacer les retours à la ligne par des <br>
                    contentDiv.innerHTML = text.replace(/\n/g, '<br>');
                    
                    const timeDiv = document.createElement('div');
                    timeDiv.className = 'message-time';
                    timeDiv.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                    
                    messageDiv.appendChild(contentDiv);
                    messageDiv.appendChild(timeDiv);
                    chatMessages.appendChild(messageDiv);
                    
                    // Scroll vers le bas
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }

                // Fonction pour trouver une réponse
                function findResponse(question) {
                    question = question.toLowerCase().trim();
                    
                    // Chercher une correspondance exacte ou partielle dans la base de connaissances
                    for (let key in knowledgeBase) {
                        if (question.includes(key)) {
                            return knowledgeBase[key];
                        }
                    }
                    
                    // Vérifier les mots-clés supplémentaires
                    if (question.includes('service') || question.includes('fonctionnalité')) {
                        return knowledgeBase['services'];
                    }
                    if (question.includes('comment') && (question.includes('médecin') || question.includes('medecin'))) {
                        return knowledgeBase['consultation médicale'];
                    }
                    if (question.includes('comment') && question.includes('score')) {
                        return knowledgeBase['score de santé'];
                    }
                    if (question.includes('quoi') || question.includes('c\'est') || question.includes('quest-ce')) {
                        if (question.includes('stress')) return knowledgeBase['coach stress'];
                        if (question.includes('nutrition')) return knowledgeBase['nutrition'];
                        if (question.includes('fitness')) return knowledgeBase['fitness'];
                        if (question.includes('stat')) return knowledgeBase['statistiques'];
                        if (question.includes('temps') || question.includes('planning')) return knowledgeBase['emploi du temps'];
                        if (question.includes('robot') || question.includes('assistant')) return knowledgeBase['robot'];
                    }
                    
                    // Réponse par défaut aléatoire
                    return defaultResponses[Math.floor(Math.random() * defaultResponses.length)];
                }

                // Fonction pour envoyer une question
                function sendQuestion() {
                    const question = userQuestion.value.trim();
                    
                    if (question) {
                        // Ajouter le message de l'utilisateur
                        addMessage('user', question);
                        
                        // Vider l'input
                        userQuestion.value = '';
                        
                        // Simuler une réponse du robot après un court délai
                        setTimeout(() => {
                            const response = findResponse(question);
                            addMessage('robot', response);
                        }, 500);
                    }
                }

                // Envoyer la question avec le bouton
                sendQuestionBtn.addEventListener('click', sendQuestion);

                // Envoyer la question avec la touche Entrée
                userQuestion.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        sendQuestion();
                    }
                });
            });

            // Fonctions globales pour les boutons rapides
            function askAboutServices() {
                const chatMessages = document.getElementById('chatMessages');
                const userQuestion = document.getElementById('userQuestion');
                userQuestion.value = "Quels sont les services disponibles ?";
                document.getElementById('sendQuestionBtn').click();
            }

            function askAboutConsultation() {
                const userQuestion = document.getElementById('userQuestion');
                userQuestion.value = "Comment consulter un médecin ?";
                document.getElementById('sendQuestionBtn').click();
            }

            function askAboutStress() {
                const userQuestion = document.getElementById('userQuestion');
                userQuestion.value = "Qu'est-ce que le coach stress ?";
                document.getElementById('sendQuestionBtn').click();
            }

            function askAboutNutrition() {
                const userQuestion = document.getElementById('userQuestion');
                userQuestion.value = "Comment fonctionne la nutrition ?";
                document.getElementById('sendQuestionBtn').click();
            }

            function askAboutFitness() {
                const userQuestion = document.getElementById('userQuestion');
                userQuestion.value = "Comment fonctionne le fitness ?";
                document.getElementById('sendQuestionBtn').click();
            }

            function askAboutStats() {
                const userQuestion = document.getElementById('userQuestion');
                userQuestion.value = "Voir mes statistiques";
                document.getElementById('sendQuestionBtn').click();
            }
        </script>
